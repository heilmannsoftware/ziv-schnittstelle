  K [note: "kein Bearbeitszyklus"]
  J [note: "jährlich"]
  G [note: "gerades Jahr"]
  U [note: "ungerades Jahr"]
  D [note: "im jedem durch drei teilbaren Jahr."]
  E [note: "jeweils ein Jahr nach einem durch drei teilbaren Jahr."]
  Z [note: "jeweils zwei Jahre nach einem durch drei teilbaren Jahr."]
  F [note: "in jedem durch fünf teilbaren Jahr."]
  EF [note: "jeweils ein Jahr nach einem durch fünf teilbaren Jahr."]
  ZF [note: "jeweils zwei Jahre nach einem durch fünf teilbaren Jahr."]
  DF [note: "jeweils drei Jahre nach einem durch fünf teilbaren Jahr."]
  VF [note: "jeweils vier Jahre nach einem durch fünf teilbaren Jahr."]
  EM [note: "einmalig"]
  AUE [note: "anlassbezogene Überprüfung (§ 15 SchfHwG)"]
  K1 [note: "einmal im Jahr."]
  K2 [note: "zweimal im Jahr."]
  K3 [note: "dreimal im Jahr."]
  K4 [note: "viermal im Jahr."]
  K6 [note: "sechsmal im Jahr."]
  K8 [note: "achtmal im Jahr."]
}

