  44BImSchV_Art _ZusatzkennzeichnungFeuerstaettenkategorie44BImschV [note: '§ 19_B | Kennzeichnung der Art der Feuerungsanlage nach der 44. BImSchV. | Siehe Kennzeichnungstabelle 2.2.1.7']
  44BImSchV_FWL_max float [note: '§ 19_B | Maximale Feuerungswaermeleistung in kW nach Typenschild. Stichwort: Anzugeben bei einer Feuerstaette nach 44. BImSchV']
  44BImSchV_Aggregationsregel bool [note: '§ 19_B | Eine oder mehrere Feuerstaetten unterliegen der Aggregationsregel der 44. BImSchV']
  // TODO der Pool muss ausgelagert werden
  44BImSchV_Aggregationspool_ float [note: '§ 19_B | Feld zur Sammlung der Feuerstätten IDs.']
  // TODO Das sollte eher ausgelagert werden oder wir brauchen 2 Felder. Ein Textfeld und ein Enum Feld wo genau spezifiziert wird was der Text enhält
  Genehmigungsbeduerftig text [note: '§ 19_B | Dokumnetation, ob die Anlage möglicherweise immissionschutzrechtlich genehmigungsbedürftig ist oder nicht!']
  Baujahr int [note: '§ 19_K | Baujahr der Feuerstaette']
  Brennstoff _BrennstoffBImSchV [note: '§ 19_K | Brennstoff der Feuerstaette | Siehe Kennzeichnungstabelle 2.2.2.1']
  // TODO Zulässig und Eingesetzte Brennstoffe ist eine Liste und muss somit ausgelagert werden
  // Zulaessige_Brennstoffart _BrennstoffBImSchV [note: '§ 19_B | Zulaessige Brennstoffe der Feuerstaette | Siehe Kennzeichnungstabelle 2.2.2.1 Es koennen mehrere Brennstoffe fuer eine Feuerstaette geeignet sein jedoch bei einer Messung nur ein Brennstoff verwendet werden. Diese werden durch Semikolon getrennt.']
  // Eingesetzte_Brennstoffart _BrennstoffBImSchV [note: '§ 19_B | Beschreibung der Brennstoffe die vorgehalten werden. Für jeden eingesetzten Brennstoffe wird ein Messergebnis angelegt. | Siehe Kennzeichnungstabelle 2.2.2.1 Es koennen mehrere Brennstoffe fuer eine Feuerstaette vorgehalten werden. Teilmenge von Zulaessige_Brennstoffart. Diese werden durch Semikolon getrennt.']
  Errichtung date [note: '§ 19_K | Errichtungsdatum der Feuerstaette']
  Waermeaustauscher_Hersteller text [note: '§ 19_B | Herstellername des Waermeaustauschers.']
  Waermeaustauscher_Typ text [note: '§ 19_B | Waermeaustauscher Typ.']
  Waermeaustauscher_HerstellerNr text [note: '§ 19_B | Herstellernummer des Waermeaustauschers.']
  Zwei_Messstellen bool [note: 'QS | Merkmal, ob Feuerstaette zwei Messstellen besitzt.']
  Nutzung _Nutzung [note: '§ 19_B | Nutzungsart der Feuerstaette.']
  GEG_Pruefung bool [note: '§ 19_B | Merkmal; das eine GEG-Pruefung notwendig ist.']
  Feuerstaetten_Ident text [note: 'QS | zusaetzliche Feuerstaettenidentifzierung, z.B. zum matchen alte Schluesselwerte']
  Art _Feuerstaettenart [note: '§ 19_K | Art des Waermeerzeugers. Beispiel fuer Feuerstaetten mit Sonderabgasverlustgrenzwerten: Wurstkessel, Backofen, Großkuechen, Luftprozessanlagen, ... | Siehe Kennzeichnungstabelle 2.2.1']
  Art_der_Anlage _ArtDerAnlageBImschV [note: '§ 19_K | Anlagenbeschreibung der Anlage (ehemals Anlagenart nach 1.BImSchV) | Siehe Kennzeichnungstabelle 2.2.5']
  Feuerstaetten_Text text [note: 'QS | Textuelle Beschreibung der Feuerstaette']
  // Brenner sollte ggf. die spezifischen Feuerstätten ausgelagert werden. Nicht alle Feuerstätten haben einen Brenner
  Brenner_HerstellerNr text [note: '§ 19_B | Herstellernummer des Brenners.']
  Brenner_Art _Brennerart [note: '§ 19_B | Angabe ueber die Betriebsweise der Feuerstaette.']
  Verriegelung bool [note: '§ 19_B | Merkmal, ob die Feuerstaette gegenueber anderen Feuerstaetten verriegelt ist. Synonym: Vorrangschaltung']
  Ein_Mehrstoffbetrieb _BrennstoffKombination [note: '§ 19_B | Angabe mit welchem Brennstoff(en) die Anlage betrieben wird. | Siehe Kennzeichnungstabelle 2.2.2 Zulässige Werte 1 bis 7']
  Verwendbarkeitsnachweis _Verwendbarkeitsnachweis [note: '§ 19_B | Nachweis der Verwendbarkeit der Anlage.']
  Angabe_Abgasanlage _FeuerstaetteAbgasanlage [note: '§ 19_B | Angabe, ob die Feuerstätte eine Abgasanlage hat oder nicht und es sich ggf. um eine systemzertifizierte Abgasanlage handelt.']
  Raumluftabhaengig bool [note: '§ 19_K | Merkmal, dass Feuerstaette raumluftabhaengig ist. J = raumluftabhaengig N = raumluftunabhaengig.']
  Stroemungssicherung bool [note: '§ 19_B | Merkmal, das Feuerstaette eine Stroemungssicherung besitzt. Synomym: Ausgleichsoeffnung. siehe zukuenftige Regelbildung | Siehe Kennzeichnungstabelle Blatt 2.2.3']
  Luftumspuelt bool [note: '§ 19_B | Merkmal, das Feuerstaette deren unter Ueberdruck stehenden Teile des Abgasweges verbrennungsluftumspuelt ist.']
  Aussenwand bool [note: '§ 19_B | Merkmal, dass Abgasfuehrung der Feuerstaette durch die Aussenwand erfolgt.']
  Gemeinsame_Schacht bool [note: '§ 19_B | Merkmal, das Abgasfuehrung zum Anschluss an gemeinsamen Schacht fuer Luft- und Abgas erfolgte.']
  LAS bool [note: '§ 19_B | Merkmal, das Verbrennungsluftzu- und Abgasabfueuehrung zum Anschluss an ein Luft-Abgas-System ist.']
  Gepruefte_Verbrennungsluft bool [note: '§ 19_B | Merkmal, ob geprueuefte Verbrennungsluftzu- und Abgasfueuehrung vorliegt.']
  Energetische_Nutzung _EnergetischeNutzung [note: '§ 19_B | Art der energetischen Nutzung einer Feuerstaette. | Siehe Kennzeichnungstabelle 2.2.6']
  TRGI _TRGI [note: '§ 19_B | TRGI Kennzeichen. Beispiel fuer Kaminofen: FB21 | Siehe Kennzeichnungstabelle 2.2.3']
  TRGI_Zusatz _TRGIZusatz [note: '§ 19_B | Zusaetzliche Kennzeichnung der Feuerstaette. | Siehe Kennzeichnungstabelle 2.2.4']
  Benutzungsintensitaet _Benutzungsintensitaet [note: '§ 19_K | Kennzeichen fuer die Intensitaet der Benutzung der Feuerstaette. | Siehe Kennzeichnungstabelle 4.1']
  // Nummer_Anlage-Feuerstaettenbescheid_Feuerstaette int [note: '§ 19_K | Verweis auf ID Bescheid_Positionen']
  Feuerstaettenstatus _FeuerstaetteStatus [note: '§ 19_K | Beschreibt den Status der Feuerstaette ']
  Ausnahmegenehmigung_Behoerde bool [note: '§ 19_B | Es liegt eine schriftliche Ausnahmegenehmigung der zuständigen Behoerde vor.']
  //  TODO Referenz auf PDF Dokumente
  // Ausnahmegenehmigung_Behoerde_Dokumente int [note: '§ 19_B | Verweis auf entsprechendes PDF-Dokument']
  Austausch_Frist_Behoerde_BImSchV_Datum date [note: '§ 19_K | Behoerdlich festgesetzte Außerbetriebnahme der Feuersaettte. Anmerkung: Abweichend von den Vorgaben der 1. BImSchV']
  // TODO hier fehlt der Grenzwert selbst von der Behörde
  Grenzwert_Frist_Behoerde_BImSchV_Datum date [note: '§ 19_K | Behoerdlich festgesetzter Grenzwert der Feuersaettte. Anmerkung: Abweichend von den Vorgaben der 1. BImSchV']
  //  TODO Referenz auf PDF Dokumente
  // Schreiben_Behoerde_Fristverlaengerung_BImSchV int [note: '§ 19_K | Verweis auf PDF-Dokument – Schreiben der Behoerde hinsichtlich Fristverlaengerung']
  Etagenheizung_GEG24 bool [note: '§ 19_B | Merkmal, ob die Feuerstätte eine Etagenheizung ist.']
  Etagenheizung_ERF_Austausch_GEG24 bool [note: '§ 19_B | Merkmal, ob die ERF mit fossilen Brennstoffen betrieben wird und nach der Wärmeplanung ausgestauscht wurde.']
}

Table Gasfeuerstaette {
  ID_Gasfeuerstaette int [pk, increment, unique]
  // ID_Feuerstaette int [note: 'V | Verweis auf Datenmodell Objekt Feuerstaette (ID_Feuerstaette steht stellvertretend fuer ID_Gebaeude_Gebaeudeteil +ID_Nutzungseinheit+ID_Wohnung+ID_Raum+Id_Feuerstaette). Eine Feuerstaette kann eine Gasfeuerstaette sein. Siehe auch „Ein_Mehrstoffbetrieb“.']
