Table Nutzungseinheit {
  ID_Nutzungseinheit int [pk, increment, unique]
  // ID_Gebaeude_Gebaeudeteil int [note: 'V | Verweis auf das Datenmodell Objekt Gebaeude_Gebaeudeteil. Eine Nutzungseinheit ist in einem Gebaeude/Gebaeudeteil.']
  // ID_Eigentuemer int [note: 'V | Verweis auf das Datenmodell Objekt Eigentuemer. Eine Nutzungseinheit kann einen vom Gebaeude/Gebaeudeteil abweichenden Eigentuemer besitzen.']
  // ID_Empfaenger int [note: 'V | Verweis auf das Datenmodell Objekt (Rechnungs-) Empfaenger. Eine Nutzungseinheit hat einen Rechnungsempfaenger.']
  // ID_Verwalter int [note: 'V | Verweis auf das Datenmodell Objekt Verwalter.']
  UST_frei bool [note: 'QS | Merkmal, ob bei der Rechnungsstellung eine Umsatzsteuer anfaellt, z.B. fuer Arbeiten im Amerikanische Konsulat oder Freihafen (Hamburg), ist UST frei.']
  // TODO Feuerstättenschau sollte in die eigene Struktur Feurstättenschau. Hier aber speziell für die Nutzungseinheit. Sollte nochmals überdacht werden
  // Feuerstaettenschau date [note: '§ 19_K | Datum der letzten Feuerstaettenschau.']
  Feuerstaettenschau_Begehung_noetig bool [note: '§ 19_K | Nutzungseinheit muss zur Feuerstaettenschau begangen werden.']
  Unbeheizter_Raum bool [note: '§ 19_B | Nutzungseinheit besitzt unbeheizte Raeume mit unzureichender Daemmung von Waermeverteilungsleitungen und Armaturen (GEG)']
  Besitzverh_geaendert_zum date [note: '§ 19_B | Datum, an dem die Nutzungseinheit verkauft wurde. Stichwort: Gebäudeenergiegesetz (GEG) Beratung nach 1. BImSchV']
  Sondereigentum bool [note: '§ 19_B | Kennzeichnung der Nutzungseinheit als Sondereigentum zur Kennzeichnung Schnittelle (intern Softwarehersteller)']
  Haustyp_TRGI _HaustypTRGI [note: '§ 19_B | Haustyp nach TRGI 1 bis 7 zur Berechnung der ausreichenden Verbrennungsluftversorgung von Feuerstätten | Siehe Kennzeichnungstabelle 3.2']
  Haustyp_N50 float [note: '§ 19_B | Gemessener n50-Wert zur Berechnung der ausreichenden Verbrennungsluftversorgung von Feuerstätten']
}

Table Wohnung {
  ID_Wohnung int [pk, increment, unique]
  // ID_Gebaeude_Gebaeudeteil int [note: 'V | Verweis auf das Datenmodell Objekt Gebaeude_Gebaeudeteil. Abgeleitet aus dem Datenmodell Objekt Nutzungseinheit.']
