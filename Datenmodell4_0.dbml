Table Meta {
  Abgabe datetime [not null, default: 'now()', note: 'Zeitstempel wann die Datei erstellt wurde']
  Version_Modell float [not null, default: 4.0, note: 'Datenmodell Versionsnummer']
  Software text [not null, note: 'Name der Erstellersoftware']
  Software_Version text [not null, note: 'Version der Erstellersoftware']
  Geschaeftsjahr int [not null, note: 'Abgegebenes Geschäftsjahr']
}

