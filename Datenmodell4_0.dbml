  // ID_Kommunikation int [note: 'V | Verweis auf das Objekt Kommunikation (Stichwort: Mieteradresse)']
  Mieter_Vorname text [note: '§ 19_K | Vorname des Mieters.']
  Mieter_Nachname text [note: '§ 19_K | Nachname des Mieters bzw. Namensbezeichnung einer Institution.']
  Geschoss _Etage [note: '§ 19_K | Geschossangabe der Wohnung. | Siehe Kennzeichnungstabelle 3.1.2']
  Lage1 _Lage1 [note: '§ 19_B | Erste Beschreibung der Lage im Geschoss.']
  Lage2 _Lage2 [note: '§ 19_B | Zweite Beschreibung der Lage im Geschoss bzgl. der ersten Beschreibung.']
  // TODO Seelbach - In Hamburg gibt es nur die Lage3 Bezeichnung daher sollte das auch § 19_B werden
  Lage3 int [note: 'QS | Lage im Geschoss fuer freie Nummerierung, z.B. bei Laubengaengen oder Hamburg']
  Geschoss_Freitext text [note: 'QS | Textuelle Geschossangabe, wenn keine Angaben zu Lage1 und Lage2 gemacht wurden.']
  Unbenutzt bool [note: '§ 19_B | Merkmal, das Wohnung unbenutzt bzw. leer steht.']
}

Table Raum {
  ID_Raum int [pk, increment, unique]
  // ID_Gebaeude_Gebaeudeteil int [note: 'V | Verweis auf das Datenmodell Objekt Gebaeude_Gebaeudeteil. Abgeleitet aus dem Datenmodell Objekt Wohnung.']
