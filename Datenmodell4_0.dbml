  ID_Nutzungseinheit int [not null, ref: > Nutzungseinheit.ID_Nutzungseinheit, note: '§ 19_K | Referenz auf die Nutzungseinheit.']
  ID_Kommunikation_Wohnungseigentuemer int [ref: > Kommunikation.ID_Kommunikation, note: '§ 19_K | Wohnungseigentümer bzw. Sprecher bei Eigentümergemeinschaft zum Zeitpunkt des Kehrbuchzeitraums.']
