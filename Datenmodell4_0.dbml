  ID_Gebaeude_Gebaeudeteil int [not null, ref: > Gebaeude_Gebaeudeteil.ID_Gebaeude_Gebaeudeteil, note: '§ 19_K | Referenz auf das Gebäude/Gebäudeteil.']
