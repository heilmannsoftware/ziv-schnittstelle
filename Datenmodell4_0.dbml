  AD_A [note: "Erläuterung: Arbeiten über Dach (Verkehrsweg, Arbeitsplatz und Absturzsicherung) - (Standfläche A) | Hinweise: Nur bei Standfläche A"]
  UD_B [note: "Erläuterung: Arbeiten unter Dach (maximaler Abstand zur Mündung 5 m) - (Standfläche B) | Hinweise: Nur bei Standfläche B"]
  UD_C [note: "Erläuterung: Arbeiten unter Dach (maximaler Abstand zur Mündung 15 m) - (Standfläche C) | Hinweise: Nur bei Standfläche C"]
