//   ID_Innung int [pk, increment, unique]
//   Name text [not null, note: 'Name der Innung']
//   Bundesland _Bundesland
// }

Table Kommunikation {
  ID_Kommunikation int [pk, increment, unique]
  Festnetz_1 text [note: 'NEIN |Primäre Festnetznummer']
  Festnetz_2 text [note: 'NEIN |Sekundäre Festnetznummer']
  Mobilfunk_1 text [note: 'NEIN |Primäre Mobilfunknummer']
  Mobilfunk_2 text [note: 'NEIN |Sekundäre Mobilfunknummer']
  Fax text [note: 'NEIN |Faxnummer']
  EMail_Kommunikation text [note: 'NEIN |Primäre E-Mail Adresse']
  EMail_Dokumente text [note: 'NEIN |Abweichende E-Mail Adresse für den Versand von Dokumenten']
  EMail_ERechnung text [note: 'NEIN |Abweichende E-Mail Adresse für den Versand von elektronischen Rechnungen']
  LeitwegID text [note: 'NEIN |Leitweg-Identifikationsnummer für den Versand von E-Rechnungen']
  Homepage text [note: 'QS |Homepage']
  Ansprechpartner text [note: 'QS |Ansprechpartner']
  Strasse text [note: '§ 19_K |Straße']
  Hausnummer text [note: '§ 19_K |Hausnummer']
  Postfach text [note: '§ 19_K |Postfach']
  PLZ text [note: '§ 19_K | Postleitzahl']
  Ort text [not null, note: '§ 19_K | Ort']
  Land text [not null, note: '§ 19_K |Länderkürzel nach ISO 3166-1 Alpha-2 Standard (Deutschland = DE)']
  // DIN 5008
  // Beispiel:
  // Zeile_A - Einschreiben -
  // Zeile_B bBSF Florian Feger, Fegerstr. 24, 24242 Fegerstadt
  // Zeile_1 Herr Dr.
  // Zeile_2 Fridolin Mustermann
  // Zeile_3 Abteilung Marketing
  // Zeile_4 Musterstrasse 2–A - Z
  // Zeile_5 12345 Musterort
  // Zeile_6
  Zeile_A text [note: '§ 19_K |Zusätze und Vermerke - A']
  Zeile_B text [note: '§ 19_K |Zusätze und Vermerke - B']
  Zeile_C text [note: '§ 19_K |Zusätze und Vermerke - C']
  Zeile_1 text [note: '§ 19_K |Anschriftenfeld - 1']
  Zeile_2 text [note: '§ 19_K |Anschriftenfeld - 2']
  Zeile_3 text [note: '§ 19_K |Anschriftenfeld - 3']
  Zeile_4 text [note: '§ 19_K |Anschriftenfeld - 4']
  Zeile_5 text [note: '§ 19_K |Anschriftenfeld - 5']
  Zeile_6 text [note: '§ 19_K |Anschriftenfeld - 6']
}

Table Fremdfirma {
  ID_Fremdfirma int [pk, increment, unique]
  Name text [not null, note: 'QS | Name der Fremdfirma']
  Ausfuehrender text [not null, note: 'QS | Name der ausführenden Person']
  ID_Kommunikation int [ref: - Kommunikation.ID_Kommunikation, note: 'QS | Kommunikation Fremdfirma']
}

Table Ort {
  ID_Ort int [pk, increment, unique]
  Name text [note: '§ 19_K |Ortsname']
}

Table Strasse {
  ID_Strasse int [pk, increment, unique]
  Name text [note: '§ 19_K | Straßenname']
  Strassencode text [note: '§ 19_B | Strassenidentifizierung (code) der von Behoerden vorgegeben wurde.']
  ID_Ort text [not null, ref: > Ort.ID_Ort, note: '§ 19_K | Ort']
}

Table Grundstueck {
  ID_Grundstueck int [pk, increment, unique]
  Name text [note: 'Kurze Beschreibung Grundstück']
  Flurnummer text [note: 'Flurnummer']
  Gemeindung text [note: 'Gemeindename in dem das Grunstück liegt. Synonym: Bezirksamt, Ortsteil']
  Baublocknummer text [note: 'Baublocknummer nach Gemarkungsliste']
  Blocknummer text [note: 'Interne Blocknummer durch bBSF vergeben. Synonym: Laufende Nummer']
  Regionalschluessel text [note: '12-stelliger Schlüssel zur eindeutigen Identifizierung einer Gemeinde mit den Bestandteilen: Bundesland (2 Stellen), Regierungsbezirk (1 Stelle), Kreis (2 Stellen), Gemeindeverband (4 Stellen) und Gemeinde (3 Stellen).']
  ID_Kommunikation_Verwalter int [ref: > Kommunikation.ID_Kommunikation, note: 'Verwalter des Gründstücks']
  ID_Strasse int [not null, ref: > Strasse.ID_Strasse, note: 'Straße']
}

Table Grundstueck_Eigentuemer {
  ID_Grundstueck_Eigentuemer int [pk, increment, unique]
  ID_Grundstueck int [not null, ref: > Grundstueck.ID_Grundstueck, note: 'Grundstueck zu dem dieser Eigentuemer gehoert.']
  ID_Kommunikation int [not null, ref: > Kommunikation.ID_Kommunikation, note: 'Eigentuemer (Person/Firma).']
  Anteil text [note: 'Anteil des Eigentuemers, z.B. 1/2, 50%.']
  Sprecher bool [note: 'Sprecher der Eigentueemergemeinschaft.']
}

Table Gebaeude_Gebaeudeteil {
  ID_Gebaeude_Gebaeudeteil int [pk, increment, unique, note: 'Sollte der Arbeitsreihenfolge / Sortierfolge entsprechen']
  // Sortierfolge int
  Hausnummer text [note: 'Hausnummer']
  PLZ text [note: 'Postleitzahl']


  //ID_Dokument text
  //ID_Mangel text
  UST_frei bool [note: 'QS | Merkmal, ob bei der Rechnungsstellung eine Umsatzsteuer anfaellt, z.B. fuer Arbeiten im Amerikanische Konsulat oder Freihafen (Hamburg), ist UST frei.']

  //ID_Mitarbeiter text
  //ID_Vertreter text
  //ID_Vertreter_Behoerde text

  // ToDo
  // Feuerstaettenschau_letzte text
  // Feuerstaettenschau_vorletzte text
  // Feuerstaettenschau_Ergebnis_letzte text
  // Feuerstaettenschau_Ergebnis_vorletzte text
  // Feuerstaettenschau_Plantermin text
  // Feuerstaettenschau_fruehstens text
  // Feuerstaettenschau_Bemerkung_letzte text
  // Feuerstaettenschau_Bemerkung_vorletzte text

  Geschosszahl int [note: 'QS | Gesamtanzahl der Geschosse für das Gebäude']
  Wirtschaftseinheit text [note: 'QS | Nummer der Wirtschaftseinheit']
  Zusammengelegte_Arbeit bool [note: 'QS | Merkmal, das Arbeiten zusammen ausgefuehrt werden.']
  Bemerkung_Arbeitsbuch text [note: 'QS | Bemerkung zum Arbeitsbucheintrag']
  Besitzverhaeltnis_geaendert date [note: '§ 19_B | Datum an dem das Gebaeude /Gebaeudeteil verkauft wurde. Stichwort: Gebäudeenergiegesetz (GEG)']
  GEG bool [note: '§ 19_B | Gebaeude unterliegt dem Anwendungsbereich der GEG']
  Baujahr date [note: '§ 19_B | Datum des Bauantrages Stichwort: Gebäudeenergiegesetz (GEG)']
  Verbrauchssektor_Energie int [note: '§ 19_B | Gibt die Nutzung des Gebaeudes an wie z. B. GHD oder Industrie Stichwort: Emissionskataster Anmerkung: Früher Datenfeld_"Gebaeude_Nutzung"']
  Gebaeude_ident text [note: 'QS | Zusaetzliche Gebaeudeidentifzierung, z.B. zum matchen alte Schluesselwerte']
  GEG24_Gebauede_Status _GebaeudestatusGEG [note: '§ 19_B | Siehe Kennzeichnungstabelle Nr. 3.1.1.6']
  GEG24_Waermeplanung_vorhanden bool [note: '§ 19_B | Merkmal ob eine Wärmeplanung vorhanden ist']
  GEG24_Waermeplanung_veroeffentlicht date [note: '§ 19_B | Merkmal, ab wann die Wärmeplanung aktiv ist.']
  GEG24_Kommune_gross bool [note: '§ 19_B | Kommune mit mehr als 100.000 Einwohner']
  GEG24_Gebaeudeart _ArtGebaeudeErgaenzungGEG24 [note: '§ 19_B | Siehe Kennzeichnungstabelle 3.1.1.5']
  GEG24_Etagenheizung_erste_ausgetauscht date [note: '§ 19_B | Datum, an dem die erste Etagenheizung oder ERF mit fossilien Brennstoffen im Gebäude ausgetauscht wurde und dadurch Fristen beginnen.']
  // ToDo
  // Betriebsanweisung_Gefaehrdungsbeurteilung_0bjektbezogen text [note: '§ QS | ']
  ID_Grundstueck int [not null, ref: > Grundstueck.ID_Grundstueck, note: 'Grundstück Gebäude']
  ID_Kommunikation_Mieter int [ref: > Kommunikation.ID_Kommunikation, note: 'Mieter Gebäude']
  ID_Kommunikation_Verwalter int [ref: > Kommunikation.ID_Kommunikation, note: 'Verwalter Gebäude']
  ID_Kehrbezirk int [not null, ref: > Kehrbezirk.ID_Kehrbezirk, note: 'Kehrbezirk']
}

Table Gebaeude_Eigentuemer {
  ID_Gebaeude_Eigentuemer int [pk, increment, unique]
  ID_Gebaeude_Gebaeudeteil int [not null, ref: > Gebaeude_Gebaeudeteil.ID_Gebaeude_Gebaeudeteil, note: 'Gebaeude/Gebaeudeteil zu dem dieser Eigentuemer gehoert.']
  ID_Kommunikation int [not null, ref: > Kommunikation.ID_Kommunikation, note: 'Eigentuemer (Person/Firma).']
  Anteil text [note: 'Anteil des Eigentuemers, z.B. 1/2, 50%.']
  Sprecher bool [note: 'Sprecher der Eigentueemergemeinschaft.']
}

Table Gebaeudeeigenschaft {
  ID_Gebaeudeeigenschaft int [pk, increment, unique]
  Eigenschaft _GebaeudeEigenschaft [note: '§ 19_B | Beschreibung der Eigenschaft des Gebaeudes']
  Kommentar text [note: 'QS | Freitext zur weiteren Beschreibung des Gebaeudes-bzw. Gebaeudeteils, z.B. Kernsanierung, Gasuhr gesperrt etc']
  Funktion _ArtGebaeude [note: '§ 19_B | Siehe Kennzeichnungstabelle 3.1.1']
  ID_Gebaeude_Gebaeudeteil int [ref: > Gebaeude_Gebaeudeteil.ID_Gebaeude_Gebaeudeteil, note: '§ 19_B | Gebäude']
}

// -- AB HIER nochmals Relationen prüfen

Table Abgasanlage {
  ID_Abgasanlage int [pk, increment, unique]
  // ID_Gebaeude_Gebaeudeteil int [note: 'V | Verweis auf das Datenmodell Objekt Gebaeude_Gebaeudeteil. Eine Abgasanlage steht in einem Gebaeude/Gebaeudeteil.']
  // ID_Abschnitt int [note: 'V | Verweis auf das Datenmodell Objekt Abschnitt. Eine Abgasanlage kann mehere Abschnitte haben.']
  // ID_Feuerstaette int [note: 'V | Verweis auf das Datenmodell Objekt Feuerstaette. Eine oder mehere Feuerstaetten sind an einer Abgasanlage angeschlossen. Hinweis: § 19 Abs. 1 Nr. 2']
  // ID_Gefaehrdungsbeurteilung int [note: 'V | Verweis auf das Datenmodell Objekt Gefaehrdungsbeurteilung.']
  // ID_Feste_Brennstoffe_Ableitbedingungen int [note: 'V | Verweis auf das Datenmodell Objekt Ableitbedingungen für feste Brennstoffe Hinweis: Trifft nur bei Abgasanlagen zu an denen Feuerstätten für feste Brennstoffe angeschlossen sind.']
  Art _AbgasanlageArt [note: '§ 19_K | Beschreibung der Abgasanlage. | Siehe Kennzeichnungstabelle 2.1.1']
  Bearbeitungszyklus _Bearbeitungszyklus [note: '§ 19_B | Zyklus in dem die Abgasanlage zu reinigen ist. Wenn der Bearbeitungdzyklus angegeben ist, muss der entsprechende Abschnitt ausgelagert werden. | Siehe Kennzeichnungstabelle 4.2']
  Kehrung_Herabsetzung bool [note: '§ 19_B | Merkmal, ob die Abgasanlage aufgrund der Anwendung des § 1 Abs. 5a einer herabgesetzten Kehrung unterliegt. Anmerkung: Kann nur bei Feuerstätten für feste Brennstoffe nach Anlage 1 Nr. 1.3 1.5. und 1.6 KÜO auftreten!']
  Vorschornstein bool [note: 'QS | Merkmal, das Vorschornstein gereinigt wird.']
  Nummer int [note: '§ 19_B | Nummer der Abgasanlage. Siehe auch ZIV-Arbeitsblatt Nr. 202. Anmerkung: Die Nummer(n) müssen übergeben werden, wenn die Dachskizze Bestandteil des Feuerstaettenbescheides ist.']
  Gruppennummer int [note: '§ 19_B | Gruppennummer der Abgasanlagen. Synonym: SchornsteingruppenNR']
  Berechnungstyp int [note: 'QS | Berechnungstyp nach der eine Abgasanlage berechnet wird.']
  Berechnungswert float [note: 'QS | Berechnungswert in Abhaengigkeit des Berechnungstyps.']
  Aussen bool [note: '§ 19_B | Merkmal, ob Schornstein ein Aussenschornstein ist. (Bei Abgasanlagen außerhalb von Gebaeuden werden maximal 3 m berechnet.)']
  Beginn _Etage [note: 'QS | Geschossangabe in dem die Abgasanlage beginnt in Stroemungsrichtung. Dachskizze leitet diese Informationen ab. | Siehe Kennzeichnungstabelle 3.1.2']
  Ende _Etage [note: 'QS | Geschossangabe in dem die Abgasanlage endet in Stroemungsrichtung. Dachskizze leitet diese Informationen ab. | Siehe Kennzeichnungstabelle 3.1.2']
  Ausfuehrungshinweis text [note: 'QS | Angaben zur Arbeitsausfuehrung an der Abgasanlage, z.B. Weg zur Abgasanlage, oder andere Besonderheiten']
  Gueltig_von date [note: '§ 19_B | Datum ab dem die Abgasanlage Gueltigkeit besitzt. (Startdatum)']
  Gueltig_bis date [note: '§ 19_B | Datum, bis wann die Abgasanlage Gueltigkeit besitzt. (Enddatum)']
  Freistehend bool [note: '§ 19_B | Merkmal, dass Abgasanlage freistehend ist.']
  Grosschornstein bool [note: '§ 19_B | Merkmal, das es sich um einen Grosschornstein handelt, Flaeche an der Sohle > 10.000 cm²']
  Hersteller text [note: '§ 19_B | Hersteller der Abgasanlage']
  Typ text [note: '§ 19_B | Abgasanlagentyp']
  Verwendbarkeitsnachweis _Verwendbarkeitsnachweis [note: '§ 19_B | Nachweis der Verwendbarkeit der Anlage.']
  Verwendbarkeitsnachweis_Text text [note: '§ 19_B | Nachweis der Verwendbarkeit der Abgasanlage gemaeß LBO, z.B. CE-Zeichen, UE-Zeichen, Zulassung, Pruefzeugnis, Zustimmung im Einzelfall']
  Hinterlueftung _AbgasanlageHinterlueftung [note: '§ 19_B | Anforderungen an eine eventuelle Hinterlueftung der Abgasleitung']
  DOP_Nummer_Abgasanlage text [note: '§ 19_B | Nummer der DOP']
  Laenge_gestreckt float [note: '§ 19_B | Gestreckte Laenge der Abgasanlage in Meter.']
  Laenge_frei float [note: '§ 19_B | Laenge der Abgasanlage die sich im Freien befindet, in Meter.']
  Temperaturklasse _Temperaturklasse18160 [note: '§ 19_B | Temperaturklasse (Taaa) | Siehe Kennzeichnungstabelle 2.1.3.1']
  Druckklasse _Druckklasse18160 [note: '§ 19_B | Druckklasse (Nx/Px/Hx) | Siehe Kennzeichnungstabelle 2.1.3.2']
  Kondensatbestaendigkeitsklasse _Kondensatbestaendigkeitsklasse18160 [note: '§ 19_B | Kondensatbestaendigkeitsklasse (D/W) | Siehe Kennzeichnungstabelle 2.1.3.3']
  Korrosionswiderstandsklasse _Korrossionswiderstandsklasse18160 [note: '§ 19_B | Korrosionswiderstandsklasse (1/2/3) | Siehe Kennzeichnungstabelle 2.1.3.4']
  Russbrandbestaendigkeitsklasse _Russbrandbestaendigkeitsklasse18160 [note: '§ 19_B | Russbrandbestaendigkeitsklasse (G / O) | Siehe Kennzeichnungstabelle 2.1.3.5']
  Abstand_brennbare_Baustoffe float [note: '§ 19_B | Abstand zu brennbaren Baustoffen in mm.']
  Feuerwiderstandsklasse _Feuerwiderstandsklasse18160 [note: '§ 19_B | Feuerwiderstandsklasse (Lzz) | Siehe Kennzeichnungstabelle 2.1.3.7']
  Material _Material [note: '§ 19_B | Materialangabe des Abschnittes einer Abgasanlage. | Siehe Kennzeichnungstabelle 2.1.4']
  Waermdurchlasswiderstand float [note: '§ 19_B | Abmessungen und Waermedurchlasswiderstand (AW)']
  Bauart_18160 _AbgasanlageBauart18160 [note: '§ 19_B | Merkmal fuer die Kennzeichnung der Abgasanlage. z.B. Bauart_18160 = 3 und Abgasanlagen_art = 11 -> Systemschornstein.']
  Benutzungsintensitaet _Benutzungsintensitaet [note: '§ 19_B | Kennzeichen fuer die Intensitaet der Benutzung der Abgasanlage. | Siehe Kennzeichnungstabelle 4.1']
  // Nummer_AnlageFeuerstaettenbescheid_Abgasanlage int [note: '§ 19_K | Verweis auf ID Bescheid_Positionen']
  ID_Gebaeude_Gebaeudeteil int [not null, ref: > Gebaeude_Gebaeudeteil.ID_Gebaeude_Gebaeudeteil, note: 'Gebäude']
}


Table Abschnitt {
  ID_Abschnitt int [pk, increment, unique]
  Sortiernummer int [note: 'QS | Reihenfolge des Abschnitts innerhalb der Abgasanlage.']
  // ID_Abschnitt_Eltern int [note: 'V | Identifikation des Abschnittsbeginns.']
  // ID_Abschnitt_Kind int [note: 'V | Identifikation des nachfolgenden Abschnitts.']
  // ID_Abgasanlage int [note: 'V | Verweis auf das Datenmodell Objekt Abgasanlage.']
  // ID_Feuerstaette int [note: 'V | Verweis auf das Datenmodell Objekt Feuerstaette.']
  // ID_Gebaeude_Gebaeudeteil int [note: 'V | Verweis auf das Datenmodell Objekt Gebaeude_Gebaeudeteil.']
  // ID_Raumlueftungsleitung int [note: 'V | Verweis auf das Datenmodell Objekt Raumluftoeffnung.']
  // ID_Raumluftoeffnung int [note: 'V | Verweis auf das Datenmodell Objekt Raumluftoeffnung.']
  // ID_Lueftungsanlage int [note: 'V | Verweis auf das Datenmodell Objekt Lueftungsanlage.']
  Errichtung date [note: '§ 19_B | Errichtungsdatum der Abgasanlage.']
  Dicht_geschweisst bool [note: '§ 19_B | Merkmal, ob Abgasanlage dicht geschweisst ist.']
  Betriebsart _AbschnittBetriebsart [note: '§ 19_K | Betriebsart der Abgasanlage']
  WirksameHoehe float [note: '§ 19_B | Gesamte wirksame Hoehe der Abgasanlage in Meter.']
