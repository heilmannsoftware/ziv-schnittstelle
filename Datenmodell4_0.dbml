  BW_STU [note: "Regierungspräsidium Stuttgart (Baden-Württemberg)"]
  BY_OBB [note: "Regierung von Oberbayern (Bayern)"]
  BY_NDB [note: "Regierung von Niederbayern (Bayern)"]
  BY_OPF [note: "Regierung von Oberpfalz (Bayern)"]
  BY_OFR [note: "Regierung von Oberfranken (Bayern)"]
  BY_MFR [note: "Regierung von Mittelfranken (Bayern)"]
  BY_UFR [note: "Regierung von Unterfranken (Bayern)"]
  BY_SCH [note: "Regierung von Schwaben (Bayern)"]
  BE_BER [note: "Berlin (Berlin)"]
  BB_BRA [note: "Brandenburg (Brandenburg)"]
  HB_BRE [note: "Bremen (Bremen)"]
  HH_HAM [note: "Hamburg (Hamburg)"]
  HE_HES [note: "Hessen (Hessen)"]
  MV_MVP [note: "Mecklenburg-Vorpommern (Mecklenburg-Vorpommern)"]
