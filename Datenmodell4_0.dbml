  BW [note: "Baden-Württemberg"]
  BY [note: "Bayern"]
  BE [note: "Berlin"]
  BB [note: "Brandenburg"]
  HB [note: "Bremen"]
  HH [note: "Hamburg"]
  HE [note: "Hessen"]
  MV [note: "Mecklenburg-Vorpommern"]
  NI [note: "Niedersachsen"]
  NW [note: "Nordrhein-Westfalen"]
  RP [note: "Rheinland-Pfalz"]
  SL [note: "Saarland"]
  SN [note: "Sachsen"]
  ST [note: "Sachsen-Anhalt"]
  SH [note: "Schleswig-Holstein"]
  TH [note: "Thüringen"]
}

