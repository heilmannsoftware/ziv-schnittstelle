  AL_SEC [note: "Holme, Sprossen, Stufen, Rutschsicherung und Kippsicherung in Ordnung | Matrix: 1.3"]
  DSO_OK [note: "Durchsteigeöffnung in Ordnung | Matrix: 1.4.1, 1.4.2, 1.4.3"]
  LDS_OK [note: "Laufstege, Dachtritte und Standflächen in Ordnung | Matrix: 1.4.1, 1.4.2, 1.4.3"]
  SS_OK [note: "Seitenschutz i.O. | Matrix: 1.4.1, 1.4.2, 1.4.3"]
  GEL_OK [note: "Geländer in Ordnung (z.B.: Seitenschutz, Oberlichter Flachdach) | Matrix: 1.4.1, 1.4.2, 1.4.3"]
  SF_OK [note: "Standfläche in Ordnung | Matrix: 1.4.2, 1.4.3, 1.4.4"]
  SS_REQ [note: "erforderlicher Seitenschutz in Ordnung | Matrix: 1.4.2, 1.4.3, 1.4.4"]
  LRP_OK [note: "Lichtraumprofil in Ordnung | Matrix: 1.4.2, 1.4.3, 1.4.4"]
  RETT [note: "Rettungskonzept | Matrix: 1.4.5"]
  PSGA [note: "PSGA | Matrix: 1.4.5"]
  VW [note: "Verkehrsweg | Matrix: 1.4.5"]
  RB [note: "Ruhebühnen | Matrix: 1.4.5"]
  AP [note: "Arbeitsplätze | Matrix: 1.4.5"]
  URO [note: "Verkehrswege und Standflächen müssen frei von Stolperfallen sein. Sie müssen ausreichend beleuchtet sein. Verkehrswege und Standflächen müssen ein ausreichendes Lichtraumprofil aufweisen. | Matrix: 1.4.4"]
}

