  Anzahl_Waagerechte int [note: '§ 19_K | Anzahl waagerechte Teile der Abgasanlagen (Verbindungsstück)']
  Anzahl_Feuerstaetten int [note: '§ 19_K | Anzahl der Feuerstätten oder ähnlicher Anlagen']
  Anzahl_Verbrennungsluftversorgung int [note: '§ 19_K | Anzahl der Verbrennungsluftversorgung und evtl. Sicherheitseinrichtungen']
  Anzahl_Dunstabzugsanlagen int [note: '§ 19_K | Anzahl der Dunstabzugsanlagen']
  Anzahl_Belueftungsanlagen int [note: '§ 19_K | Anzahl der Be- und Entlüftungsanlagen']
  Freifeld_Anzahl int [note: '§ 19_K | Anzahl der überprüften Anlagen und Einrichtungen']
  Freifeld_Beschreibung text [note: '§ 19_K | Beschreibung der überprüften Anlagen und Einrichtungen']
  // TODO Doppelt
  // keine_Maengel bool [note: '§ 19_K | Es wurden keine sichtbaren Maengel festgestellt']
  Maengel bool [note: '§ 19_K | Es wurden folgende Mängel festgestellt J / N']
  Freifeld_Maengel text [note: '§ 19_K | Beschreibung der Mägel Freitext alternativ Verknüfpfung auf ID_Mangel']
  Maengel_ohne_Gefahr bool [note: '§ 19_K | Mängel ohne unmittelbare Gefahr']
  Maengelfrist date [note: '§ 19_K | Mängelfrist zur Behebung']
  Maengelpruefung_erforderlich bool [note: '§ 19_K | Angabe, ob eine Mängelprüfung erforderlich ist']
  Bemerkung text [note: '§ 19_K | Bemerkung zur durchgeführten Feuerstättenschau']
  Datum_Bescheinigung date [note: '§ 19_K | Datum an dem die Bescheinigung ausgefüllt worden ist.']
  ID_Vertreter int [ref: > Vertreter.ID_Vertreter, note: '§ 19_K | Optionaler Vertreter der die Feuerstättenschau durchgeführt hat.']
}

Table Feuerstaettenbescheid_Grunddaten {
  ID_Feuerstaettenbescheid_Grunddaten int [pk, increment, unique]
  ID_Gebaeude_Gebaeudeteil int [not null, ref: > Gebaeude_Gebaeudeteil.ID_Gebaeude_Gebaeudeteil, note: '§ 19_B | Feuerstaettenbescheid bezieht sich auf ein Gebaeude/Gebaeudeteil']
  Ausstellungsdatum date [note: '§ 19_K | Ausstellungsdatum des Feuerstättenbescheides']
  Nummer text [note: '§ 19_K | Eindeutige Nummer des Feuerstättenbescheids. Ein Gebäude kann einen oder mehrere Feuerstättenbescheide besitzen.']
  Naechste_FS int [note: '§ 19_K wenn ausgefüllt und an Kunden mitgeteilt. | Jahr der nächsten Feuerstättenschau']
  Zusatz text [note: '§ 19_B | Zusätzliche Vereinbarungen die im Feuerstättenbescheid niedergechrieben wurden.']
  Art _FeuerstaettenbescheidArt [note: '§ 19_B | Art des Feuerstättenbescheides']
  Empfaenger int [ref: > Kommunikation.ID_Kommunikation, note: '§ 19_B | Empfaenger des Feuerstättenbescheids']
}

Table Bescheid_Position {
  ID_Bescheid_Position int [pk, increment, unique]
  ID_Feuerstaettenbescheid_Grunddaten int [not null, ref: > Feuerstaettenbescheid_Grunddaten.ID_Feuerstaettenbescheid_Grunddaten, note: '§ 19_B | Position gehoert zu Feuerstaettenbescheid']
  Positionsnummer int [note: '§ 19_K | Eindeutige Nummer der beschriebenen Anlage auf dem Feuerstättenbescheid. Dient zur leichteren Identifikation der Anlagen. (Positionsnummer)']
  Art_Standort_Anlage text [note: '§ 19_K | Art und Standort der Anlage aus dem Feuerstättenbescheid']
  Verweis_Anlage text [note: '§ 19_K | Verweis auf eine Anlage (Dokument z. B. Dachskizze) zum Feuerstättenbescheid']
  Rechtsgrundlage text [note: '§ 19_K | Auflistung der Kürzel der auszuführenden Arbeiten. Aus diesen Kürzeln kann die Rechtsgrundlage ersehen werden. Siehe Ordner Z_Bund-Spezifikation: Kürzel- und Gebührenverzeichnis_Hoheitliche Tätigkeiten_2013-04-17+Formeln z.B. Nr. 3.1 Anlage 1 zu § 1 Abs. 4 KUEO']
  Anlagetyp _Anlagetyp [not null, note: '§ 19_K | Typ der zugeordneten Anlage (bestimmt Zieltabelle von ID_Anlage)']
  ID_Anlage int [not null, note: '§ 19_K | ID der zugeordneten Anlage (Zieltabelle ergibt sich aus Anlagetyp)']
}

Table Bescheid_Termin_Position {
  ID_Bescheid_Termin_Position int [pk, increment, unique]
  ID_Bescheid_Position int [not null, ref: > Bescheid_Position.ID_Bescheid_Position, note: '§ 19_B | Termin bezieht sich auf eine Position des Feuerstättenbescheids']
  Start_Zeitraum date [note: '§ 19_K | Alle aufgelisteten Startzeitpunkte für die Zeiträume im Feuerstättenbescheid.']
  Ende_Zeitraum date [note: '§ 19_K | Alle aufgelisteten Endzeitpunkte für die Zeiträume im Feuerstättenbescheid.']
}

Table Leistung {
  ID_Leistung int [pk, increment, unique]
  ID_Gebaeude_Gebaeudeteil int [not null, ref: > Gebaeude_Gebaeudeteil.ID_Gebaeude_Gebaeudeteil, note: 'QS | Leistung bezieht sich auf ein Gebaeude/Gebaeudeteil']
  Kuerzel text [note: 'QS | Verweis auf die Leistungen nach der Landeskehrordnung']
  Beschreibung text [note: 'QS | Textuelle Beschreibung der ausgeführten Tätigkeit.']
