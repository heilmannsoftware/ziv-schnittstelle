//Kennzeichnung 5.2 Verkehrsweg
Enum _Verkehrsweg {
  FT [note: "Erläuterung: Verkehrsweg Flur und Treppen | Hinweise: Bei Standfläche A bis D"]
  BT [note: "Erläuterung: Bodentreppe | Hinweise: Bei Standfläche A bis D"]
  AL [note: "Erläuterung: Anlegleitern | Hinweise: Bei Standfläche A bis D"]
  AD_A [note: "Erläuterung: Arbeiten über Dach (Verkehrsweg, Arbeitsplatz und Absturzsicherung) - (Standfläche A) | Hinweise: Nur bei Standfläche A"]
  UD_B [note: "Erläuterung: Arbeiten unter Dach (maximaler Abstand zur Mündung 5 m) - (Standfläche B) | Hinweise: Nur bei Standfläche B"]
  UD_C [note: "Erläuterung: Arbeiten unter Dach (maximaler Abstand zur Mündung 15 m) - (Standfläche C) | Hinweise: Nur bei Standfläche C"]
  RO_D [note: "Erläuterung: Arbeiten an der unteren Reinigungsöffnung - (Standfläche D) | Hinweise: Nur bei Standfläche D"]
  BA_E [note: "Erläuterung: Besondere Arbeitsplätze / freistehende Schornsteine - (Standfläche E) | Hinweise: Nur bei Standfläche E"]
}

