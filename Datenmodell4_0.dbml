Table Meta {
  Abgabe datetime [not null, default: 'now()', note: '§ 19_B |Zeitstempel wann die Datei erstellt wurde']
  Version_Modell float [not null, default: 4.0, note: '§ 19_B |Datenmodell Versionsnummer']
  Software text [not null, note: '§ 19_B |Name der Erstellersoftware']
  Software_Version text [not null, note: '§ 19_B |Version der Erstellersoftware']
  Geschaeftsjahr int [not null, note: '§ 19_B |Abgegebenes Geschäftsjahr']
}

Table Untere_Aufsichtsbehoerde {
  ID_Untere_Aufsichtbehoerde int [pk, increment, unique]
  Name text [note: '§ 19_K |Kurze Beschreibung der unteren Aufsichtsbehörde']
  ID_Kommunikation int [ref: - Kommunikation.ID_Kommunikation, note: '§ 19_K |Kommunikation untere Aufsichtsbehörde']
}

Table Kehrbezirk {
  ID_Kehrbezirk int [pk, increment, unique]
  Kennung_QM text [not null, note: '§ 19_K |Bundeseinheitliche eindeutige Nummer des Kehrbezirkes nach dem QM/UM-Verfahren (L.XX-I.XX-K.XX-B.XXX).']
  Kennung_Land text [note: '§ 19_K |Länderspezifische Kehrbezirkskennung.']
  Kennung_BAFA text [note: '§ 19_B |Dem Kehrbezirk zugeteilte Identifikationsnummer zur Abrechnung der geklebten Energieetiketten.']
  Kennung_BAFA_Aufteilung text [note: '§ 19_B |Egänzungsnummer bei Aufteilung eines Kehrbezirkes. Nur erforderlich für die Erhebung (ZStat).']
  Guetesiegel_BSF text [note: 'NEIN |Gütesigelnummer für bBSF (steht für hoheitliche Schornsteinfegerarbeiten) Beispiel: BSF 1234567']
  Guetesiegel_SFB text [note: 'NEIN |Gütesiegelnummer für Schornsteinfegerbetrieb (steht für sog. freie Schornsteinfegerarbeiten im Wettbewerb) Beispiel: SFB 1234567']
  bBSF_Vorname text [note: '§ 19_K |Vorname bBSFs']
  bBSF_Name text [not null, note: '§ 19_K |Nachname bBSFs']
  bBSF_Strasse text [note: '§ 19_K |Straße bBSFs']
  bBSF_PLZ text [note: '§ 19_K |Postleitzahl bBSFs']
  bBSF_Ort text [note: '§ 19_K |Ort bBSFs']
  bBSF_Postfach text [note: 'NEIN |Postfach bBSFs']
  bBSF_EMail text [note: 'NEIN |E-Mail bBSFs']
  bBSF_Festnetz text [note: 'NEIN |Festnetznummer bBSFs']
  bBSF_Mobil text [note: 'NEIN |Mobilfunknummer bBSFs']
  bBSF_Fax text [note: 'NEIN |Faxnummer bBSFs']
  bBSF_Homepage text [note: 'NEIN |Homepage bBSFs']
  //bBSF_Stellung text [note: 'Stellung bBSFs nach SchfHwG']
  bBSF_Bestellzeitraum_am date [note: '§ 19_K |Tag der Bestellung bBSFs für den Bezirk']
  bBSF_Bestellzeitraum_bis date [note: '§ 19_K |Endtag der Bestellung bBSFs für den Bezirk']
  bBSF_Bankname text [note: 'NEIN |Konto Bankname bBSFs']
  bBSF_IBAN text [note: 'NEIN |Konto IBAN bBSFs']
  bBSF_BIC text [note: 'NEIN |Konto BIC bBSFs']
  bBSF_GlaeubigerID text [note: 'NEIN |Gläubiger-Identifikationsnummer bBSFs']
  bBSF_Steuernummer text [note: 'NEIN |Steuernummer bBSFs']
  bBSF_UmsatzsteuerID text [note: 'NEIN |Umsatzsteuer-Identifikationsnummer bBSFs']
  ID_Vertreter_11 int [not null, ref: - Vertreter.ID_Vertreter, note: '§ 19_K |Vertreter nach § 11 SchfHwG']
  ID_Vertreter_11a int [ref: - Vertreter.ID_Vertreter, note: '§ 19_K |Behördlicher Vertreter nach § 11a SchfHwG']
  Innung _Innung [not null, note: '§ 19_K |Innungszugehörigkeit']
  Obere_Aufsichtsbehoerde _Obere_Aufsichtsbehoerde [note: '§ 19_K | Obere Aufsichtsbehörde']
  Bundesland _Bundesland [note: '§ 19_K | Bundesland des Kehrbezirks']
}

Table Mitarbeiter {
  ID_Mitarbeiter int [pk, increment, unique]
  Vorname text [note: 'QS |Vorname Mitarbeiter']
  Name text [not null, note: 'QS |Nachnname Mitarbeiter']
  ID_Kommunikation int [ref: - Kommunikation.ID_Kommunikation, note: 'QS |Kommunikation Mitarbeiter']
  ID_Vertreter_11b int [ref: - Vertreter.ID_Vertreter, note: '§ 19_K |Vertreter nach § 11b SchfHwG (Feuerstättenschau)']
}

Table Vertreter {
  ID_Vertreter int [pk, increment, unique]
  Vorname text [note: '§ 19_K |Vorname Vertreter']
  Name text [not null, note: '§ 19_K |Nachname Vertreter']
  Ernannt_am date [not null, note: '§ 19_K |Tag der Ernennung des Vertreter']
  Ernannt_bis date [not null, note: '§ 19_K |Endtag der Ernennung des Vertreter']
  ID_Kommunikation int [ref: - Kommunikation.ID_Kommunikation, note: '§ 19_K | Kommunikation Vertreter']
}

Table Kommunikation {
  ID_Kommunikation int [pk, increment, unique]
  Festnetz_1 text [note: 'NEIN |Primäre Festnetznummer']
  Festnetz_2 text [note: 'NEIN |Sekundäre Festnetznummer']
  Mobilfunk_1 text [note: 'NEIN |Primäre Mobilfunknummer']
  Mobilfunk_2 text [note: 'NEIN |Sekundäre Mobilfunknummer']
  Fax text [note: 'NEIN |Faxnummer']
  EMail_Kommunikation text [note: 'NEIN |Primäre E-Mail Adresse']
  EMail_Dokumente text [note: 'NEIN |Abweichende E-Mail Adresse für den Versand von Dokumenten']
  EMail_ERechnung text [note: 'NEIN |Abweichende E-Mail Adresse für den Versand von elektronischen Rechnungen']
  LeitwegID text [note: 'NEIN |Leitweg-Identifikationsnummer für den Versand von E-Rechnungen']
  Homepage text [note: 'QS |Homepage']
  Ansprechpartner text [note: 'QS |Ansprechpartner']
  Strasse text [note: '§ 19_K |Straße']
  Hausnummer text [note: '§ 19_K |Hausnummer']
  Postfach text [note: '§ 19_K |Postfach']
  PLZ text [note: '§ 19_K | Postleitzahl']
  Ort text [not null, note: '§ 19_K | Ort']
  Land text [not null, note: '§ 19_K |Länderkürzel nach ISO 3166-1 Alpha-2 Standard (Deutschland = DE)']
  // DIN 5008
  // Beispiel:
  // Zeile_A - Einschreiben -
  // Zeile_B bBSF Florian Feger, Fegerstr. 24, 24242 Fegerstadt
  // Zeile_1 Herr Dr.
  // Zeile_2 Fridolin Mustermann
  // Zeile_3 Abteilung Marketing
  // Zeile_4 Musterstrasse 2–A - Z
  // Zeile_5 12345 Musterort
  // Zeile_6
  Zeile_A text [note: '§ 19_K |Zusätze und Vermerke - A']
  Zeile_B text [note: '§ 19_K |Zusätze und Vermerke - B']
  Zeile_C text [note: '§ 19_K |Zusätze und Vermerke - C']
  Zeile_1 text [note: '§ 19_K |Anschriftenfeld - 1']
  Zeile_2 text [note: '§ 19_K |Anschriftenfeld - 2']
  Zeile_3 text [note: '§ 19_K |Anschriftenfeld - 3']
  Zeile_4 text [note: '§ 19_K |Anschriftenfeld - 4']
  Zeile_5 text [note: '§ 19_K |Anschriftenfeld - 5']
  Zeile_6 text [note: '§ 19_K |Anschriftenfeld - 6']
}

Table Fremdfirma {
  ID_Fremdfirma int [pk, increment, unique]
  Name text [not null, note: 'QS | Name der Fremdfirma']
  Ausfuehrender text [not null, note: 'QS | Name der ausführenden Person']
  ID_Kommunikation int [ref: - Kommunikation.ID_Kommunikation, note: 'QS | Kommunikation Fremdfirma']
}

Table Ort {
  ID_Ort int [pk, increment, unique]
  Name text [note: '§ 19_K |Ortsname']
}

Table Strasse {
  ID_Strasse int [pk, increment, unique]
  Name text [note: '§ 19_K | Straßenname']
  Strassencode text [note: '§ 19_B | Strassenidentifizierung (code) der von Behörden vorgegeben wurde.']
  ID_Ort int [not null, ref: > Ort.ID_Ort, note: '§ 19_K | Ort']
}

Table Grundstueck {
  ID_Grundstueck int [pk, increment, unique]
  Name text [note: 'QS | Kurze Beschreibung Grundstück']
  Flurnummer text [note: 'QS | Flurnummer']
  Gemeindung text [note: 'QS | Gemeindename in dem das Grunstück liegt. Synonym: Bezirksamt, Ortsteil']
  Baublocknummer text [note: 'QS | Baublocknummer nach Gemarkungsliste']
  Blocknummer text [note: 'QS | Interne Blocknummer durch bBSF vergeben. Synonym: Laufende Nummer']
  ID_Kommunikation_Verwalter int [ref: > Kommunikation.ID_Kommunikation, note: '§ 19_K | Verwalter des Gründstücks']
  ID_Kommunikation_Eigentuemer int [ref: > Kommunikation.ID_Kommunikation, note: '§ 19_K | Eigentümer des Gründstücks']
  ID_Strasse int [not null, ref: > Strasse.ID_Strasse, note: '§ 19_K | Straße']
}

Table Gebaeude_Gebaeudeteil {
  ID_Gebaeude_Gebaeudeteil int [pk, increment, unique, note: 'Sollte der Arbeitsreihenfolge / Sortierfolge entsprechen']
  Hausnummer text [note: '§ 19_K | Hausnummer']
  PLZ text [note: '§ 19_K | Postleitzahl']
  UST_frei bool [note: 'QS | Merkmal, ob bei der Rechnungsstellung eine Umsatzsteuer anfällt, z.B. für Arbeiten im Amerikanische Konsulat oder Freihafen (Hamburg), ist UST frei.']
  Geschosszahl int [note: 'QS | Gesamtanzahl der Geschosse für das Gebäude']
  Wirtschaftseinheit text [note: 'QS | Nummer der Wirtschaftseinheit']
  Zusammengelegte_Arbeit bool [note: 'QS | Merkmal, das Arbeiten zusammen ausgeführt werden.']
  Bemerkung_Arbeitsbuch text [note: 'QS | Bemerkung zum Arbeitsbucheintrag']
  Besitzverhaeltnis_geaendert date [note: '§ 19_B | Datum an dem das Gebäude /Gebäudeteil verkauft wurde. Stichwort: Gebäudeenergiegesetz (GEG)']
  GEG bool [note: '§ 19_B | Gebäude unterliegt dem Anwendungsbereich der GEG']
  Baujahr date [note: '§ 19_B | Datum des Bauantrages Stichwort: Gebäudeenergiegesetz (GEG)']
  Verbrauchssektor _VerbrauchssektorEnergie [note: '§ 19_B | Gibt die Nutzung des Gebäudes an wie z. B. GHD oder Industrie Stichwort: Emissionskataster Anmerkung: Früher Datenfeld_"Gebaeude_Nutzung"']
  Gebaeude_ident text [note: 'QS | Zusätzliche Gebäudeidentifzierung, z.B. zum matchen alte Schlüsselwerte']
  GEG24_Gebauede_Status _GebaeudestatusGEG [note: '§ 19_B | Siehe Kennzeichnungstabelle Nr. 3.1.1.6']
  GEG24_Waermeplanung_vorhanden bool [note: '§ 19_B | Merkmal ob eine Wärmeplanung vorhanden ist']
  GEG24_Waermeplanung_veroeffentlicht date [note: '§ 19_B | Merkmal, ab wann die Wärmeplanung aktiv ist.']
  GEG24_Kommune_gross bool [note: '§ 19_B | Kommune mit mehr als 100.000 Einwohner']
  GEG24_Gebaeudeart _ArtGebaeudeErgaenzungGEG24 [note: '§ 19_B | Siehe Kennzeichnungstabelle 3.1.1.5']
  GEG24_Etagenheizung_erste_ausgetauscht date [note: '§ 19_B | Datum, an dem die erste Etagenheizung oder ERF mit fossilien Brennstoffen im Gebäude ausgetauscht wurde und dadurch Fristen beginnen.']
  Betriebsanweisung_Gefaehrdungsbeurteilung_Objektbezogen text [note: 'QS | Betriebsanweisung Gefährdungsbeurteilung objektbezogen']
  ID_Grundstueck int [not null, ref: > Grundstueck.ID_Grundstueck, note: '§ 19_K |Grundstück Gebäude']
  ID_Kommunikation_Mieter int [ref: > Kommunikation.ID_Kommunikation, note: 'QS | Mieter Gebäude']
  ID_Kommunikation_Verwalter int [ref: > Kommunikation.ID_Kommunikation, note: '§ 19_K | Verwalter Gebäude']
  ID_Kehrbezirk int [not null, ref: > Kehrbezirk.ID_Kehrbezirk, note: '§ 19_K | Kehrbezirk']
}

Table Gebaeude_Eigentuemer {
  ID_Gebaeude_Eigentuemer int [pk, increment, unique]
  ID_Gebaeude_Gebaeudeteil int [not null, ref: > Gebaeude_Gebaeudeteil.ID_Gebaeude_Gebaeudeteil, note: '§ 19_K | Gebäude/Gebäudeteil zu dem dieser Eigentümer gehört.']
  ID_Kommunikation int [not null, ref: > Kommunikation.ID_Kommunikation, note: '§ 19_K | Eigentümer (Person/Firma).']
  Sprecher bool [note: '§ 19_B | Sprecher der Eigentümergemeinschaft.']
}

Table Gebaeudeeigenschaft {
  ID_Gebaeudeeigenschaft int [pk, increment, unique]
  Eigenschaft _GebaeudeEigenschaft [note: '§ 19_B | Beschreibung der Eigenschaft des Gebäudes']
  Kommentar text [note: 'QS | Freitext zur weiteren Beschreibung des Gebäudes-bzw. Gebäudeteils, z.B. Kernsanierung, Gasuhr gesperrt etc']
  Funktion _ArtGebaeude [note: '§ 19_B | Siehe Kennzeichnungstabelle 3.1.1']
  ID_Gebaeude_Gebaeudeteil int [ref: > Gebaeude_Gebaeudeteil.ID_Gebaeude_Gebaeudeteil, note: '§ 19_B | Gebäude']
}

Table Abgasanlage {
  ID_Abgasanlage int [pk, increment, unique]
  Art _AbgasanlageArt [note: '§ 19_K | Beschreibung der Abgasanlage. | Siehe Kennzeichnungstabelle 2.1.1']
  Bearbeitungszyklus _Bearbeitungszyklus [note: '§ 19_B | Zyklus in dem die Abgasanlage zu reinigen ist. Wenn der Bearbeitungdzyklus angegeben ist, muss der entsprechende Abschnitt ausgelagert werden. | Siehe Kennzeichnungstabelle 4.2']
  Kehrung_Herabsetzung bool [note: '§ 19_B | Merkmal, ob die Abgasanlage aufgrund der Anwendung des § 1 Abs. 5a einer herabgesetzten Kehrung unterliegt. Anmerkung: Kann nur bei Feuerstätten für feste Brennstoffe nach Anlage 1 Nr. 1.3 1.5. und 1.6 KÜO auftreten!']
  Vorschornstein bool [note: 'QS | Merkmal, das Vorschornstein gereinigt wird.']
  Nummer int [note: '§ 19_B | Nummer der Abgasanlage. Siehe auch ZIV-Arbeitsblatt Nr. 202. Anmerkung: Die Nummer(n) müssen übergeben werden, wenn die Dachskizze Bestandteil des Feuerstättenbescheides ist.']
  Gruppennummer int [note: '§ 19_B | Gruppennummer der Abgasanlagen. Synonym: SchornsteingruppenNR']
  Berechnungstyp int [note: 'QS | Berechnungstyp nach der eine Abgasanlage berechnet wird.']
  Berechnungswert float [note: 'QS | Berechnungswert in Abhängigkeit des Berechnungstyps.']
  Aussen bool [note: '§ 19_B | Merkmal, ob Schornstein ein Aussenschornstein ist. (Bei Abgasanlagen außerhalb von Gebäuden werden maximal 3 m berechnet.)']
  Beginn _Etage [note: 'QS | Geschossangabe in dem die Abgasanlage beginnt in Strömungsrichtung. Dachskizze leitet diese Informationen ab. | Siehe Kennzeichnungstabelle 3.1.2']
  Ende _Etage [note: 'QS | Geschossangabe in dem die Abgasanlage endet in Strömungsrichtung. Dachskizze leitet diese Informationen ab. | Siehe Kennzeichnungstabelle 3.1.2']
  Ausfuehrungshinweis text [note: 'QS | Angaben zur Arbeitsausführung an der Abgasanlage, z.B. Weg zur Abgasanlage, oder andere Besonderheiten']
  Gueltig_von date [note: '§ 19_B | Datum ab dem die Abgasanlage Gültigkeit besitzt. (Startdatum)']
  Gueltig_bis date [note: '§ 19_B | Datum, bis wann die Abgasanlage Gültigkeit besitzt. (Enddatum)']
  Freistehend bool [note: '§ 19_B | Merkmal, dass Abgasanlage freistehend ist.']
  Grosschornstein bool [note: '§ 19_B | Merkmal, das es sich um einen Grosschornstein handelt, Fläche an der Sohle > 10.000 cm²']
  Hersteller text [note: '§ 19_B | Hersteller der Abgasanlage']
  Typ text [note: '§ 19_B | Abgasanlagentyp']
  Verwendbarkeitsnachweis _Verwendbarkeitsnachweis [note: '§ 19_B | Nachweis der Verwendbarkeit der Anlage.']
  Verwendbarkeitsnachweis_Text text [note: '§ 19_B | Nachweis der Verwendbarkeit der Abgasanlage gemäß LBO, z.B. CE-Zeichen, UE-Zeichen, Zulassung, Prüfzeugnis, Zustimmung im Einzelfall']
  Hinterlueftung _AbgasanlageHinterlueftung [note: '§ 19_B | Anforderungen an eine eventuelle Hinterlüftung der Abgasleitung']
  DOP_Nummer_Abgasanlage text [note: '§ 19_B | Nummer der DOP']
  Laenge_gestreckt float [note: '§ 19_B | Gestreckte Länge der Abgasanlage in Meter.']
  Laenge_frei float [note: '§ 19_B | Länge der Abgasanlage die sich im Freien befindet, in Meter.']
  Temperaturklasse _Temperaturklasse18160 [note: '§ 19_B | Temperaturklasse (Taaa) | Siehe Kennzeichnungstabelle 2.1.3.1']
  Druckklasse _Druckklasse18160 [note: '§ 19_B | Druckklasse (Nx/Px/Hx) | Siehe Kennzeichnungstabelle 2.1.3.2']
  Kondensatbestaendigkeitsklasse _Kondensatbestaendigkeitsklasse18160 [note: '§ 19_B | Kondensatbeständigkeitsklasse (D/W) | Siehe Kennzeichnungstabelle 2.1.3.3']
  Korrosionswiderstandsklasse _Korrossionswiderstandsklasse18160 [note: '§ 19_B | Korrosionswiderstandsklasse (1/2/3) | Siehe Kennzeichnungstabelle 2.1.3.4']
  Russbrandbestaendigkeitsklasse _Russbrandbestaendigkeitsklasse18160 [note: '§ 19_B | Russbrandbeständigkeitsklasse (G / O) | Siehe Kennzeichnungstabelle 2.1.3.5']
  Abstand_brennbare_Baustoffe float [note: '§ 19_B | Abstand zu brennbaren Baustoffen in mm.']
  Feuerwiderstandsklasse _Feuerwiderstandsklasse18160 [note: '§ 19_B | Feuerwiderstandsklasse (Lzz) | Siehe Kennzeichnungstabelle 2.1.3.7']
  Material _Material [note: '§ 19_B | Materialangabe des Abschnittes einer Abgasanlage. | Siehe Kennzeichnungstabelle 2.1.4']
  Waermdurchlasswiderstand float [note: '§ 19_B | Abmessungen und Wärmedurchlasswiderstand (AW)']
  Bauart_18160 _AbgasanlageBauart18160 [note: '§ 19_B | Merkmal für die Kennzeichnung der Abgasanlage. z.B. Bauart_18160 = 3 und Abgasanlagen_art = 11 -> Systemschornstein.']
  Benutzungsintensitaet _Benutzungsintensitaet [note: '§ 19_B | Kennzeichen für die Intensität der Benutzung der Abgasanlage. | Siehe Kennzeichnungstabelle 4.1']
  ID_Gebaeude_Gebaeudeteil int [not null, ref: > Gebaeude_Gebaeudeteil.ID_Gebaeude_Gebaeudeteil, note: '§ 19_K | Gebäude']
}

Table Abschnitt {
  ID_Abschnitt int [pk, increment, unique]
  Sortiernummer int [note: '§ 19_K | Reihenfolge des Abschnitts innerhalb der Abgasanlage/Feuerstätte.']
  Errichtung date [note: '§ 19_B | Errichtungsdatum der Abgasanlage.']
  Dicht_geschweisst bool [note: '§ 19_B | Merkmal, ob Abgasanlage dicht geschweisst ist.']
  Betriebsart _AbschnittBetriebsart [note: '§ 19_K | Betriebsart der Abgasanlage']
  WirksameHoehe float [note: '§ 19_B | Gesamte wirksame Höhe der Abgasanlage in Meter.']
  Besteigbar bool [note: '§ 19_B | Merkmal, ob Abgasanlage von innen bestiegen wird.']
  Brennstoff_Arten _BrennstoffKombination [note: '§ 19_K | benutzte Brennstoffe | Siehe Kennzeichnungstabelle 2.2.2']
  Belegungs_Arten text [note: 'QS | Abgasanlagenbelegung. Zusatzinformation für z.B. Arbeitsbuch (Einzelfeuerstätte(n) zentrale Feuerstätte(n)).']
  Querschnittsform _Querschnittsform [note: '§ 19_B | Beschreibung der Querschnittsform']
  QuerschnittWert1 float [note: '§ 19_B | Seitenabmessung 1 bzw. Durchmesser 1 in cm']
  QuerschnittWert2 float [note: '§ 19_B | Seitenabmessung 2 bzw. Durchmesser 2 in cm']
  Laenge float [note: 'QS |  Länge des Abschnittes in Meter']
  Boegen_30 int [note: '§ 19_B | Anzahl der bis 30° Bögen des Abschnitts Synonym: Knickstellen, Richtungsänderungen.']
  Boegen_45 int [note: '§ 19_B | Anzahl der Bögen > 30° bis 45° des Abschnitts Synonym: Knickstellen, Richtungsänderungen.']
  Boegen_60 int [note: '§ 19_B | Anzahl der Bögen > 45° bis 60° des Abschnitts Synonym: Knickstellen, Richtungsänderungen.']
  Boegen_90 int [note: '§ 19_B | Anzahl der Bögen > 60° bis 90° des Abschnitts Synonym: Knickstellen, Richtungsänderungen.']
  Eintrittswinkel int [note: '§ 19_B | Eintrittwinkel in den nächsten Abschnittes in Grad, bezogen auf die Achsen der Abschnitte.']
  Art _AbgasanlageArt [note: '§ 19_B | Abschnittsart. | Siehe Kennzeichnungstabelle 2.1.1']
  Nutzung _Nutzung [note: '§ 19_B | Nutzungsart des Abschnitts.']
  Ueber_Durchgangshoehe bool [note: 'QS | Merkmal, das Abschnitt über Durchgangshöhe liegt. Es werden Hilfsmittel, Steighilfen, benötigt. In Bundesländern unterschiedlich definieren i.d.R. Meterangaben.']
  Anzahl_Daemmung int [note: 'QS | Anzahl der Dämmschichten für Reinigungsöffnugen.']
  Schalldaempfer bool [note: 'QS | Merkmal, das Abschnitt Schalldämpfer besitzt.']
  Zyklon bool [note: 'QS | Merkmal, das Abschnitt einen Zyklon besitzt. Zyklon= Vorrichtung zur Entstaubung von Gasen mithilfe der Fliehkraft.']
  Abdecken bool [note: 'QS | Merkmal, ob ein Abschnitt abgedeckt werden muss.']
  Staubfreie_Reinigung bool [note: 'QS | Merkmal, das Abschnitt staubfrei gereinigt wird, z.B. mittels Staubsauger.']
  ZIV_Kennzeichen text [note: 'QS | Abgeleitet aus Kennzeichnung Schicht.']
  Temperaturklasse _Temperaturklasse18160 [note: '§ 19_B | Temperaturklasse (Taaa) | Siehe Kennzeichnungstabelle 2.1.3.1']
  Druckklasse _Druckklasse18160 [note: '§ 19_B | Gasdichtheitsklasse (Nx/Px/Hx) / Druckklasanse | Siehe Kennzeichnungstabelle 2.1.3.2']
  Kondensatbestaendigkeitsklasse _Kondensatbestaendigkeitsklasse18160 [note: '§ 19_B | Kondensatbeständigkeitsklasse (D/W) | Siehe Kennzeichnungstabelle 2.1.3.3']
  Korrosionswiderstandsklasse _Korrossionswiderstandsklasse18160 [note: '§ 19_B | Korrosionswiderstandsklasse (1/2/3) | Siehe Kennzeichnungstabelle 2.1.3.4']
