Table Untere_Aufsichtsbehoerde {
  ID_Untere_Aufsichtbehoerde int [pk, increment, unique]
  Name text [note: 'Kurze Beschreibung der unteren Aufsichtsbehörde']
  ID_Kommunikation int [ref: - Kommunikation.ID_Kommunikation, note: 'Kommunikation untere Aufsichtsbehörde']
}

Table Kehrbezirk {
  ID_Kehrbezirk int [pk, increment, unique]
  // Name text [note: 'Kurze Beschreibung des Kehrbezirks.']
  Kennung_QM text [not null, note: 'Bundeseinheitliche eindeutige Nummer des Kehrbezirkes nach dem QM/UM-Verfahren (L.XX-I.XX-K.XX-B.XXX).']
  Kennung_Land text [note: 'Laenderspezifische Kehrbezirkskennung.']
  Kennung_BAFA text [note: 'Dem Kehrbezirk zugeteilte Identifikationsnummer zur Abrechnung der geklebten Energieetiketten.']
  Kennung_BAFA_Aufteilung text [note: 'Egänzungsnummer bei Aufteilung eines Kehrbezirkes. Nur erforderlich für die Erhebung (ZStat).']
  Guetesiegel_BSF text [note: 'Gütesigelnummer für bBSF (steht für hoheitliche Schornsteinfegerarbeiten) Beispiel: BSF 1234567']
  Guetesiegel_SFB text [note: 'Gütesiegelnummer für Schornsteinfegerbetrieb (steht für sog. freie Schornsteinfegerarbeiten im Wettbewerb) Beispiel: SFB 1234567']
  // Angaben zum bBSF
  bBSF_Vorname text [note: 'Vorname bBSFs']
  bBSF_Name text [not null, note: 'Nachname bBSFs']
  bBSF_Strasse text [note: 'Straße bBSFs']
  bBSF_PLZ text [note: 'Postleitzahl bBSFs']
  bBSF_Ort text [note: 'Ort bBSFs']
  bBSF_Postfach text [note: 'Postfach bBSFs']
  bBSF_EMail text [note: 'E-Mail bBSFs']
  bBSF_Festnetz text [note: 'Festnetznummer bBSFs']
  bBSF_Mobil text [note: 'Mobilfunknummer bBSFs']
  bBSF_Fax text [note: 'Faxnummer bBSFs']
  bBSF_Homepage text [note: 'Homepage bBSFs']
  //bBSF_Stellung text [note: 'Stellung bBSFs nach SchfHwG']
  bBSF_Bestellzeitraum_am date [note: 'Tag der Bestellung bBSFs für den Bezirk']
  bBSF_Bestellzeitraum_bis date [note: 'Endtag der Bestellung bBSFs für den Bezirk']
  bBSF_Bankname text [note: 'Konto Bankname bBSFs']
  bBSF_IBAN text [note: 'Konto IBAN bBSFs']
  bBSF_BIC text [note: 'Konto BIC bBSFs']
  bBSF_GlaeubigerID text [note: 'Gläubiger-Identifikationsnummer bBSFs']
  bBSF_Steuernummer text [note: 'Steuernummer bBSFs']
  bBSF_UmsatzsteuerID text [note: 'Umsatzsteuer-Identifikationsnummer bBSFs']
  ID_Vertreter_11 int [not null, ref: - Vertreter.ID_Vertreter, note: 'Vertreter nach § 11 SchfHwG']
  ID_Vertreter_11a int [ref: - Vertreter.ID_Vertreter, note: 'Behördlicher Vertreter nach § 11a SchfHwG']
  Innung _Innung [not null, note: 'Innungszugehörigkeit']
  Obere_Aufsichtsbehoerde _Obere_Aufsichtsbehoerde
  Bundesland _Bundesland
  //Betriebsanweisung_Gefaehrdungsbeurteilung_allgemein text [note: '']
}

Table Mitarbeiter {
  ID_Mitarbeiter int [pk, increment, unique]
  Vorname text [note: 'Vorname Mitarbeiter']
  Name text [not null, note: 'Nachnname Mitarbeiter']
  ID_Kommunikation int [ref: - Kommunikation.ID_Kommunikation, note: 'Kommunikation Mitarbeiter']
  ID_Vertreter_11b int [ref: - Vertreter.ID_Vertreter, note: 'Vertreter nach § 11b SchfHwG (Feuerstättenschau)']
}

Table Vertreter {
  ID_Vertreter int [pk, increment, unique]
  Vorname text [note: 'Vorname Vertreter']
  Name text [not null, note: 'Nachname Vertreter']
  Ernannt_am date [not null, note: 'Tag der Ernennung des Vertreter']
  Ernannt_bis date [not null, note: 'Endtag der Ernennung des Vertreter']
  // Stellung wird nicht mehr benötigt weil durch die Relation klar ist welche Rolle er hat
  ID_Kommunikation int [ref: > Kommunikation.ID_Kommunikation, note: 'Kommunikation Vertreter']
}

