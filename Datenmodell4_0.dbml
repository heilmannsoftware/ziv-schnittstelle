  // ID_Betreiber int [note: 'V | Verweis auf das Datenmodell Objekt Betreiber. Abgeleitet aus dem Datenmodell Objekt Betreiber.']
  // ID_Nutzungseinheit int [note: 'V | Identifiziert die Nutzungseinheit eines Gebaeude/Gebaeudeteils.']

  Anzahl_Geschoss int [note: '§ 19_B | Gesamte Anzahl der Geschosse ueber die sich die Dunstabzugsleitung erstreckt.']
  Anzahl_Muendung int [note: '§ 19_B | Anzahl der Muendungen']
  Anzahl_Muendung_ohne_Ventilator int [note: '§ 19_B | Anzahl der Muendungen die keinen Ventilator besitzen.']
  Anzahl_Muendung_mit_Ventilator int [note: '§ 19_B | Anzahl der Muendungen die einen Ventilator besitzen.']

  Kehrpflicht_Dunstanlage bool [note: '§ 19_K | Merkmal, ob die Anlage der Kehrpflicht nach KÜO unterliegt.']
  Ueberpruefungspflicht_Dunstanlage bool [note: '§ 19_K | Merkmal, ob die Anlage der Ueberpruefungspflicht nach KÜO unterliegt.']

  Laenge float [note: '§ 19_B | Gesamtlaenge der Dunstabzugsleitung in Metern.']
  Differenzdruckschalter bool [note: '§ 19_B | Merkmal, ob Anlage einen Differenzdruckschalter besitzt.']
  Hoehe_ueber_Dach float [note: '§ 19_B | Hoehe ueber Dach der Dunstabzugleitung in Metern.']
  // TODO Geräte Kategorie ist komisch weil an der Leitung hängen ja mehrere Geräte
  Geraete_Kategorie _Feuerstaettenart [note: '§ 19_B | Geräte Kategorie | Siehe Kennzeichnungstabelle 2.2.1']
  Brennstoff _BrennstoffBImSchV [note: '§ 19_B | Eingesetzter Brennstoff der Gerate | Siehe Kennzeichnungstabelle 2.2.2.1']
  Leistung float [note: '§ 19_B | Leistung in kW']
  // TODO Mängel sollte extra sein
  Sonstige_Maengel text [note: '§ 19_K | Freitext bis 100 Zeichen']
  Maengel_Frist date [note: '§ 19_K | Enddatum der Maengelfrist']
  Bemerkung text [note: 'QS | Freitext']
  // TODO Bei Zubehör kann es mehrere geben. Das geht als Feld so nicht!
  Zubehoer _ZubehoerLueftungsanlagen [note: 'QS | Siehe Kennzeichnungstabelle 3.3 | Siehe Kennzeichnungstabelle 3.3']
//  Nummer_Anlage_Feuerstaettenbescheid_Dunstabzugsleitung int [note: '§ 19_K | Verweis auf ID Bescheid_Positionen']
}

