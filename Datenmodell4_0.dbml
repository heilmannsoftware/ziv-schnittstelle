  FEN_TUER [note: "Einrichtung zur Bedarfslüftung des Raumes - Fenster oder Tür ins Freie | Erläuterung: MFeuV § 5 Abs. 1 Nr. 4 | Sonstiges: Bedarfslüftung > 100 kW"]
  ZOA_FREI [note: "Zuluft- und Abluftöffnung direkt ins Freie | Erläuterung: MFeuV § 5 Abs. 1 Nr. 4 | Sonstiges: Bedarfslüftung > 100 kW"]
  ZAOL_FREI [note: "Zuluft- und Abluftöffnung über Leitungen ins Freie | Erläuterung: MFeuV § 5 Abs. 1 Nr. 4 | Sonstiges: Bedarfslüftung > 100 kW"]
  ZOAS_BD [note: "Zuluftöffnung und Abluftschaft | Erläuterung: MFeuV § 5 Abs. 1 Nr. 4 | Sonstiges: Bedarfslüftung > 100 kW"]
  ZLAS_BD [note: "Zuluftleitung und Abluftschacht | Erläuterung: MFeuV § 5 Abs. 1 Nr. 4 | Sonstiges: Bedarfslüftung > 100 kW"]
  ZAO_FREI [note: "Zuluftleitung und Abluftöffnung ins Freie | Erläuterung: MFeuV § 5 Abs. 1 Nr. 4 | Sonstiges: Bedarfslüftung > 100 kW"]
  ZOMA_FREI [note: "Zuluftöffnung und motorischer Abluft ins Freie | Erläuterung: MFeuV § 5 Abs. 1 Nr. 4 | Sonstiges: Bedarfslüftung > 100 kW"]
  W2X150 [note: "2 Öffnungen in der Auswand, untenliegend und obenliegend für Gasfeuerstätte > 100 kW und Abgasführung im Überdruck, 150 cm² zzgl. 1 cm² für jedes über 100 kW hinausgehende kW, | Erläuterung: MFeuV § 5 Abs. 2 Satz 1 | Sonstiges: Überdruck-Gasfeuerstätte > 100 kW Überdruckabgasabführung"]
  ZLAS_TRGI [note: "Zuleitung und Abluftschacht | Erläuterung: TRGI 8.3.2.4.2.2.2 | Sonstiges: Überdruck-Gasfeuerstätte > 100 kW Überdruckabgasabführung"]
  MEZ_1AL [note: "mechanische Zuluftzuführung und 1 Abluftleitung | Erläuterung: TRGI 8.3.2.4.2.2.3 | Sonstiges: Überdruck-Gasfeuerstätte > 100 kW Überdruckabgasabführung"]
  ZAO_HR_FREI [note: "Zu- und Abluftöffnung Heizraum direkt ins Freie | Erläuterung: MFeuV § 6 Abs. 4 | Sonstiges: Heizräume"]
  ZAL_HR_FREI [note: "Zu- und Abluftleitungen Heizraum ins Freie | Erläuterung: MFeuV § 6 Abs. 4 | Sonstiges: Heizräume"]
  ZOAS_HR [note: "Zuluftöffnung und Abluftschacht | Erläuterung: MFeuV § 6 Abs. 4 | Sonstiges: Heizräume"]
  ZLAS_HR [note: "Zuluftleitung und Abluftschacht | Erläuterung: MFeuV § 6 Abs. 4 | Sonstiges: Heizräume"]
  EUD_ZAO [note: "einwandige Überdruck-Abgasanlagen, Zu- und Abluftöffnung | Erläuterung: MFeuV § 7 Abs. 8 Nr 1 i.V TRGI Pkt. 8.3.2.5 | Sonstiges: Einwandige Überdruck-Abgasleitungen"]
  EUD_OAL [note: "einwandige Überdruck-Abgasanlagen, Zu- und Abluftleitungen | Erläuterung: MFeuV § 7 Abs. 8 Nr 1 i.V TRGI Pkt. 8.3.2.5 | Sonstiges: Einwandige Überdruck-Abgasleitungen"]
  EUD_ZOAS [note: "einwandige Überdruck-Abgasanlagen, Zuluftöffnung und Abluftschacht | Erläuterung: MFeuV § 7 Abs. 8 Nr 1 i.V TRGI Pkt. 8.3.2.5 | Sonstiges: Einwandige Überdruck-Abgasleitungen"]
  EUD_ZLAS [note: "einwandige Überdruck.-Abgasanlagen, Zuluftletungen und Abluftschacht | Erläuterung: MFeuV § 7 Abs. 8 Nr 1 i.V TRGI Pkt. 8.3.2.5 | Sonstiges: Einwandige Überdruck-Abgasleitungen"]
  C_150_FREI [note: "Gasgeräte Art C mit Gebläse ohne Zusatzkennzeichnung x, unmittelbar ins Freie führende Öffnung mit mind. 150 cm² oder 2 Öffnungen von je 75 cm² | Erläuterung: TRGI PKt. 8.3.3.1"]
}

