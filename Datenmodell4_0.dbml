  Raumluftabhaengig bool [note: '§ 19_K | Merkmal, dass Feuerstätte raumluftabhängig ist. J = raumluftabhängig N = raumluftunabhängig.']
  Stroemungssicherung bool [note: '§ 19_B | Merkmal, das Feuerstätte eine Strömungssicherung besitzt. Synomym: Ausgleichsöffnung. siehe zukünftige Regelbildung | Siehe Kennzeichnungstabelle Blatt 2.2.3']
  Luftumspuelt bool [note: '§ 19_B | Merkmal, das Feuerstätte deren unter Überdruck stehenden Teile des Abgasweges verbrennungsluftumspült ist.']
  Aussenwand bool [note: '§ 19_B | Merkmal, dass Abgasführung der Feuerstätte durch die Aussenwand erfolgt.']
  Gemeinsame_Schacht bool [note: '§ 19_B | Merkmal, das Abgasführung zum Anschluss an gemeinsamen Schacht für Luft- und Abgas erfolgte.']
  LAS bool [note: '§ 19_B | Merkmal, das Verbrennungsluftzu- und Abgasabfüührung zum Anschluss an ein Luft-Abgas-System ist.']
  Gepruefte_Verbrennungsluft bool [note: '§ 19_B | Merkmal, ob geprüüfte Verbrennungsluftzu- und Abgasfüührung vorliegt.']
  Energetische_Nutzung _EnergetischeNutzung [note: '§ 19_B | Art der energetischen Nutzung einer Feuerstätte. | Siehe Kennzeichnungstabelle 2.2.6']
  TRGI _TRGI [note: '§ 19_B | TRGI Kennzeichen. Beispiel für Kaminofen: FB21 | Siehe Kennzeichnungstabelle 2.2.3']
  TRGI_Zusatz _TRGIZusatz [note: '§ 19_B | Zusätzliche Kennzeichnung der Feuerstätte. | Siehe Kennzeichnungstabelle 2.2.4']
  Benutzungsintensitaet _Benutzungsintensitaet [note: '§ 19_K | Kennzeichen für die Intensität der Benutzung der Feuerstätte. | Siehe Kennzeichnungstabelle 4.1']
  Feuerstaettenstatus _Feuerstaettenstatus [note: '§ 19_K | Beschreibt den Status der Feuerstätte ']
  Ausnahmegenehmigung_Behoerde bool [note: '§ 19_B | Es liegt eine schriftliche Ausnahmegenehmigung der zuständigen Behörde vor.']
  Ausnahmegenehmigung_Behoerde_Dokumente int [ref: - Dokument.ID_Dokument, note: '§ 19_B | Verweis auf entsprechendes PDF-Dokument']
  Austausch_Frist_Behoerde_BImSchV_Datum date [note: '§ 19_K | Behördlich festgesetzte Außerbetriebnahme der Feuersättte. Anmerkung: Abweichend von den Vorgaben der 1. BImSchV']
  Grenzwert_Frist_Behoerde_BImSchV_Datum date [note: '§ 19_K | Behördlich festgesetzter Grenzwert der Feuersättte. Anmerkung: Abweichend von den Vorgaben der 1. BImSchV']
  Grenzwert_Behoerde_BImSchV float [note: '§ 19_K | Behördlich festgesetzter Grenzwert der Feuersättte. Anmerkung: Abweichend von den Vorgaben der 1. BImSchV']
  Schreiben_Behoerde_Fristverlaengerung_BImSchV int [ref: - Dokument.ID_Dokument, note: '§ 19_K | Verweis auf PDF-Dokument – Schreiben der Behoerde hinsichtlich Fristverlaengerung']
  Etagenheizung_GEG24 bool [note: '§ 19_B | Merkmal, ob die Feuerstätte eine Etagenheizung ist.']
  Etagenheizung_ERF_Austausch_GEG24 bool [note: '§ 19_B | Merkmal, ob die ERF mit fossilen Brennstoffen betrieben wird und nach der Wärmeplanung ausgestauscht wurde.']
}

