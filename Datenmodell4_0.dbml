  C91 [note: "Feuerstätte der Art C mit zugehöriger Abgasabführung bis über Dach. Die Verbrennungsluftzuführung erfolgt über eine zugehörige Leitung im Aufstellraum und einen bestehenden Schacht als Gebäudebestandteil. Die Mündungen befinden sich nahe beieinander im gleichen Druckbereich. | ohne Gebläse"]
  C92 [note: "Feuerstätte der Art C mit zugehöriger Abgasabführung bis über Dach. Die Verbrennungsluftzuführung erfolgt über eine zugehörige Leitung im Aufstellraum und einen bestehenden Schacht als Gebäudebestandteil. Die Mündungen befinden sich nahe beieinander im gleichen Druckbereich. | mit Gebläse hinter dem Wärmetauscher"]
  C93 [note: "Feuerstätte der Art C mit zugehöriger Abgasabführung bis über Dach. Die Verbrennungsluftzuführung erfolgt über eine zugehörige Leitung im Aufstellraum und einen bestehenden Schacht als Gebäudebestandteil. Die Mündungen befinden sich nahe beieinander im gleichen Druckbereich. | mit Gebläse vor dem Brenner"]

  C101 [note: "Feuerstätte mit zugehöriger Verbrennungsluftzu- und Abgasabführung zum Anschluss an ein bauseits vorhandenes einfach oder mehrfach belegtes Luft-Abgas-System (LAS). Die Mündungen befinden sich nahe beieinander im gleichen Druckbereich. Die Abgasabführung ist bis ins Freie für Überdruck ausgelegt. | ohne Gebläse"]
  C102 [note: "Feuerstätte mit zugehöriger Verbrennungsluftzu- und Abgasabführung zum Anschluss an ein bauseits vorhandenes einfach oder mehrfach belegtes Luft-Abgas-System (LAS). Die Mündungen befinden sich nahe beieinander im gleichen Druckbereich. Die Abgasabführung ist bis ins Freie für Überdruck ausgelegt. | mit Gebläse hinter dem Wärmetauscher"]
  C103 [note: "Feuerstätte mit zugehöriger Verbrennungsluftzu- und Abgasabführung zum Anschluss an ein bauseits vorhandenes einfach oder mehrfach belegtes Luft-Abgas-System (LAS). Die Mündungen befinden sich nahe beieinander im gleichen Druckbereich. Die Abgasabführung ist bis ins Freie für Überdruck ausgelegt. | mit Gebläse vor dem Brenner"]

  C111 [note: "Feuerstätte der Art C mit zugehöriger Verbrennungsluftzu- und Abgasabführung sowie zugehöriger einfach oder mehrfach belegter senkrechter Luft-Abgas-Leitung. Die Mündungen befinden sich nahe beieinander im gleichen Druckbereich. Die Abgasabführung ist bis ins Freie für Überdruck ausgelegt. | ohne Gebläse"]
  C112 [note: "Feuerstätte der Art C mit zugehöriger Verbrennungsluftzu- und Abgasabführung sowie zugehöriger einfach oder mehrfach belegter senkrechter Luft-Abgas-Leitung. Die Mündungen befinden sich nahe beieinander im gleichen Druckbereich. Die Abgasabführung ist bis ins Freie für Überdruck ausgelegt. | mit Gebläse hinter dem Wärmetauscher"]
  C113 [note: "Feuerstätte der Art C mit zugehöriger Verbrennungsluftzu- und Abgasabführung sowie zugehöriger einfach oder mehrfach belegter senkrechter Luft-Abgas-Leitung. Die Mündungen befinden sich nahe beieinander im gleichen Druckbereich. Die Abgasabführung ist bis ins Freie für Überdruck ausgelegt. | mit Gebläse vor dem Brenner"]

  C121 [note: "Feuerstätte der Art C mit zugehörigem Abgasanschluss an eine einfach oder mehrfach belegte bauseits vorhandene Abgasanlage und zugehöriger Verbrennungsluftzuführung aus dem Freien. Die Mündungen befinden sich in unterschiedlichen Druckbereichen. Die Abgasabführung ist bis ins Freie für Überdruck ausgelegt. | ohne Gebläse"]
  C122 [note: "Feuerstätte der Art C mit zugehörigem Abgasanschluss an eine einfach oder mehrfach belegte bauseits vorhandene Abgasanlage und zugehöriger Verbrennungsluftzuführung aus dem Freien. Die Mündungen befinden sich in unterschiedlichen Druckbereichen. Die Abgasabführung ist bis ins Freie für Überdruck ausgelegt. | mit Gebläse hinter dem Wärmetauscher"]
  C123 [note: "Feuerstätte der Art C mit zugehörigem Abgasanschluss an eine einfach oder mehrfach belegte bauseits vorhandene Abgasanlage und zugehöriger Verbrennungsluftzuführung aus dem Freien. Die Mündungen befinden sich in unterschiedlichen Druckbereichen. Die Abgasabführung ist bis ins Freie für Überdruck ausgelegt. | mit Gebläse vor dem Brenner"]

  C131 [note: "Feuersatätte der Art C mit zugehörigem Abgasanschluss an eine einfach oder mehrfach belegte zugehörige Abgasleitung und zugehöriger Verbrennungsluftzuführung aus dem Freien. Die Mündungen befinden sich in unterschiedlichen Druckbereichen. Die Abgasabführung ist bis ins Freie für Überdruck ausgelegt. | ohne Gebläse"]
  C132 [note: "Feuersatätte der Art C mit zugehörigem Abgasanschluss an eine einfach oder mehrfach belegte zugehörige Abgasleitung und zugehöriger Verbrennungsluftzuführung aus dem Freien. Die Mündungen befinden sich in unterschiedlichen Druckbereichen. Die Abgasabführung ist bis ins Freie für Überdruck ausgelegt. | mit Gebläse hinter dem Wärmetauscher"]
  C133 [note: "Feuersatätte der Art C mit zugehörigem Abgasanschluss an eine einfach oder mehrfach belegte zugehörige Abgasleitung und zugehöriger Verbrennungsluftzuführung aus dem Freien. Die Mündungen befinden sich in unterschiedlichen Druckbereichen. Die Abgasabführung ist bis ins Freie für Überdruck ausgelegt. | mit Gebläse vor dem Brenner"]

  C141 [note: "Feuerstätte der Art C mit zugehöriger Luft-Abgas-Leitung bis zur zugehörigen einfach oder mehrfach belegten senkrechten Abgasleitung und zum bauseits vorhandenen Schacht. Die Verbrennungsluftzuführung bis zur Luft-Abgas-Leitung erfolgt über den bauseits vorhandenen Schacht als Gebäudebestandteil. Die Mündungen der senkrechten Abgasleitung und des Schachtes befinden sich nahe beieinander im gleichen Druckbereich. Die Abgasabführung ist bis ins Freie für Überdruck ausgelegt. | ohne Gebläse"]
  C142 [note: "Feuerstätte der Art C mit zugehöriger Luft-Abgas-Leitung bis zur zugehörigen einfach oder mehrfach belegten senkrechten Abgasleitung und zum bauseits vorhandenen Schacht. Die Verbrennungsluftzuführung bis zur Luft-Abgas-Leitung erfolgt über den bauseits vorhandenen Schacht als Gebäudebestandteil. Die Mündungen der senkrechten Abgasleitung und des Schachtes befinden sich nahe beieinander im gleichen Druckbereich. Die Abgasabführung ist bis ins Freie für Überdruck ausgelegt. | mit Gebläse hinter dem Wärmetauscher"]
  C143 [note: "Feuerstätte der Art C mit zugehöriger Luft-Abgas-Leitung bis zur zugehörigen einfach oder mehrfach belegten senkrechten Abgasleitung und zum bauseits vorhandenen Schacht. Die Verbrennungsluftzuführung bis zur Luft-Abgas-Leitung erfolgt über den bauseits vorhandenen Schacht als Gebäudebestandteil. Die Mündungen der senkrechten Abgasleitung und des Schachtes befinden sich nahe beieinander im gleichen Druckbereich. Die Abgasabführung ist bis ins Freie für Überdruck ausgelegt. | mit Gebläse vor dem Brenner"]

  C151 [note: "Feuerstätte der Art C mit zugehöriger Luftleitung bis zum bauseits vorhandenen Schacht und zugehöriger einfach belegter Abgasleitung bis über Dach. Die Verbrennungsluftzuführung von der Mündung bis zur Luftleitung erfolgt für ein Gasgerät oder mehrere Gasgeräte über den gemeinsamen bestehenden Schacht als Gebäudebestandteil. Die Mündungen befinden sich nahe beieinander im gleichen Druckbereich. Die Abgasabführung ist bis ins Freie für Überdruck ausgelegt. | ohne Gebläse"]
  C152 [note: "Feuerstätte der Art C mit zugehöriger Luftleitung bis zum bauseits vorhandenen Schacht und zugehöriger einfach belegter Abgasleitung bis über Dach. Die Verbrennungsluftzuführung von der Mündung bis zur Luftleitung erfolgt für ein Gasgerät oder mehrere Gasgeräte über den gemeinsamen bestehenden Schacht als Gebäudebestandteil. Die Mündungen befinden sich nahe beieinander im gleichen Druckbereich. Die Abgasabführung ist bis ins Freie für Überdruck ausgelegt. | mit Gebläse hinter dem Wärmetauscher"]
  C153 [note: "Feuerstätte der Art C mit zugehöriger Luftleitung bis zum bauseits vorhandenen Schacht und zugehöriger einfach belegter Abgasleitung bis über Dach. Die Verbrennungsluftzuführung von der Mündung bis zur Luftleitung erfolgt für ein Gasgerät oder mehrere Gasgeräte über den gemeinsamen bestehenden Schacht als Gebäudebestandteil. Die Mündungen befinden sich nahe beieinander im gleichen Druckbereich. Die Abgasabführung ist bis ins Freie für Überdruck ausgelegt. | mit Gebläse vor dem Brenner"]
}

//Kennzeichnung 2.2.4 Zusätzliche Kennzeichnung zur TRGI
Enum _TRGIZusatz {
  AS [note: "Raumluftüberwachungseinrichtung | Sonstiges: Nur möglich bei Feuerstätten der Art A"]
  BS [note: "Abgasüberwachungseinrichtung | Sonstiges: Nur möglich bei Feuerstätten der Art B"]
  X [note: "zusätzliche Dichtheitsanforderungen | Sonstiges: Nur möglich bei Feuerstätten der Art C (Ausnahme Feuerstätten für flüssige und feste Brennstoffe)"]
  P [note: "bestimmungsgemäßer Abgasabführung unter Überdruck. | Sonstiges: Nur möglich bei Feuerstätten der Art B2, B4 und B5"]
  DT [note: "Abführung von feuchter Trocknungsluft gemeinsam mit Abgasanteilen über eine Leitung direkt ins Freie | Sonstiges: Nur möglich bei Feuerstätten der Art B2"]
  S [note: "Abgasleitung im bauseits vorhandenen hinterlüfteten Schacht | Sonstiges: Nur möglich bei Feuerstätten der Art B5"]
}

