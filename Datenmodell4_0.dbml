// ----------------------------------------------------------------------------
// Definition der Enums
Enum _Anlagetyp {
  Abgasanlage
  Feuerstaette
  Raumluftoeffnung
  Dunstabzuganlage_Leitung
  Lueftungsanlage
  Raumlueftung
  Raeucheranlage
  Brennstoffversorgungsanlage
}

Enum _AbschnittAnlagetyp {
  Abgasanlage [note: "Abschnitt gehört zu einer Abgasanlage"]
  Feuerstaette [note: "Abschnitt ist Verbindungsstück einer Feuerstätte"]
}

Enum _AbnahmeAnlagetyp {
  Abgasanlage
  Feuerstaette
}

Enum _MangelHerkunftstyp {
  Kehrbuch_Taetigkeit
  Kehrbuch_Abnahme
  Kehrbuch_Feuerstaettenschau
  Kehrbuch_Anlassbezogene_Ueberpruefung
}

Enum _ZubehoerAnlagetyp {
  Abschnitt
  Dunstabzuganlage_Leitung
}

Enum _DokumentHerkunftstyp {
  Gebaeude_Gebaeudeteil
  Nutzungseinheit
  Feuerstaettenbescheid_Grunddaten
  Abnahme
  Anlassbezogene_Ueberpruefung
  Pruefergebnis_Feuerstaettenschau
  Pruefergebnis_GEG
  Mess_Pruefergebnis_Gasfeuerstaette
  Mess_Pruefergebnis_Oelfeuerstaette
  Mess_Pruefergebnis_Feststofffeuerstaette_HK
  Mess_Pruefergebnis_Feststofffeuerstaette_ERF
  Mess_Pruefergebnis_Sonderfeuerstaette
  Mess_Pruefergebnis_Waermepumpe
  Mess_Pruefergebnis_Dunstabzugsleitung
  Mess_Pruefergebnis_Raumluftoeffnung
}

