  Raumart _Raum [note: '§ 19_B | Beschreibung des Aufstellraumes hinsichtlich der Nutzung | Siehe Kennzeichnungstabelle 3.1.4']
  Raumart_Zusatz _RaumZusatz [note: 'QS | Zusatzkennzeichnung fuer die Raumart. | Siehe Kennzeichnungstabelle 3.1.4.1']
  Mechanische_Entlueftung _RaumMechanischeEntlueftung [note: '§ 19_B | Merkmal, ob dem Raum mechanisch Luft entzogen wird.']
  
}

Table Feuerstaette {
  ID_Feuerstaette int [pk, increment, unique]
  // ID_Gebaeude_Gebaeudeteil int [note: 'V | Verweis auf das Datenmodell Objekt Gebaeude_Gebaeudeteil. Abgeleitet aus dem Datenmodell Objekt Raum.']
  // ID_Nutzungseinheit int [note: 'V | Verweis auf das Datenmodell Objekt Nutzungseinheit. Abgeleitet aus dem Datenmodell Objekt Raum.']
  // ID_Wohnung int [note: 'V | Verweis auf das Datenmodell Objekt Wohnung. Abgeleitet aus dem Datenmodell Objekt Raum.']
  // ID_Raum int [note: 'V | Verweis auf das Datenmodell Objekt Raum.']
  // ID_Feuerstaettenbetreiber int [note: 'V | Verweis auf das Datenmodell Objekt Feuerstaettenbetreiber. Eine Feuerstaette hat einen Feuerstaettenbetreiber.']
  // ID_Feuerstaetteneigentuemer int [note: 'V | Verweis auf das Datenmodell Objekt Feuerstaettenbetreiber. Eine Feuerstaette kann eine vom Feuerstaettenbetreiber abweichenden Feuerstaetteneigentuemer besitzen.']
