  BP_OK [note: "Bolzenplatte in Ordnung | Matrix: 1.2"]
  SB_OK [note: "Schwenkbeschlag in Ordnung | Matrix: 1.2"]
  TB_OK [note: "Treppenband in Ordnung | Matrix: 1.2"]
  AL_USE [note: "Verwendung einer Anlegeleiter in Ordnung (Stichwort: Gewerbliches Gebäude*2) | Matrix: 1.3"]
  AL_TRBS [note: "Die zu verwendende Anlegeleiter erfüllt die notwendigen Sicherheitsanforderungen der TRBS 2121 Teil 2 | Matrix: 1.3"]
  AL_FIT [note: "Die Art der Leiter passt zur durchzuführenden Tätigkeit | Matrix: 1.3"]
  AL_SEC [note: "Holme, Sprossen, Stufen, Rutschsicherung und Kippsicherung in Ordnung | Matrix: 1.3"]
  DSO_OK [note: "Durchsteigeöffnung in Ordnung | Matrix: 1.4.1, 1.4.2, 1.4.3"]
  LDS_OK [note: "Laufstege, Dachtritte und Standflächen in Ordnung | Matrix: 1.4.1, 1.4.2, 1.4.3"]
  SS_OK [note: "Seitenschutz i.O. | Matrix: 1.4.1, 1.4.2, 1.4.3"]
  GEL_OK [note: "Geländer in Ordnung (z.B.: Seitenschutz, Oberlichter Flachdach) | Matrix: 1.4.1, 1.4.2, 1.4.3"]
  SF_OK [note: "Standfläche in Ordnung | Matrix: 1.4.2, 1.4.3, 1.4.4"]
  SS_REQ [note: "erforderlicher Seitenschutz in Ordnung | Matrix: 1.4.2, 1.4.3, 1.4.4"]
  LRP_OK [note: "Lichtraumprofil in Ordnung | Matrix: 1.4.2, 1.4.3, 1.4.4"]
  RETT [note: "Rettungskonzept | Matrix: 1.4.5"]
  PSGA [note: "PSGA | Matrix: 1.4.5"]
  VW [note: "Verkehrsweg | Matrix: 1.4.5"]
  RB [note: "Ruhebühnen | Matrix: 1.4.5"]
  AP [note: "Arbeitsplätze | Matrix: 1.4.5"]
  URO [note: "Verkehrswege und Standflächen müssen frei von Stolperfallen sein. Sie müssen ausreichend beleuchtet sein. Verkehrswege und Standflächen müssen ein ausreichendes Lichtraumprofil aufweisen. | Matrix: 1.4.4"]
}

//Kennzeichnung 5.4 Bewertungssystematik-Allgemein
Enum _Bewertungssystematik {
  NA [note: "Beschreibung: nicht zutreffend | Erläuterung 1: Feld wird verwendet, wenn ein Prüfpunkt nicht zutreffend ist!"]
  WORK [note: "Beschreibung: muss bearbeitet werden | Erläuterung 1: 5 (Kennzeichnungstabelle 5.5) | Erläuterung 2: oder Feld mit automatischer Vorbelegung- Farbe \"Rosa\""]
  OK [note: "Beschreibung: in Ordnung | Erläuterung 1: 1, 2 ,3 (Kennzeichnungstabelle 5.5)"]
  NOK [note: "Beschreibung: nicht in Ordnung | Erläuterung 1: 4 (Kennzeichnungstabelle 5.5)"]
}

//Kennzeichnung 5.5 Gefährdungseinschätzung - Verkehrsweg/Standfläche
Enum _Risikoeinschaetzung {
  SGR [note: "Einschätzung: Sehr gering | Rot: 177 | Grün: 255 | Blau: 149"]
  GR [note: "Einschätzung: gering | Rot: 230 | Grün: 249 | Blau: 115"]
  AKZ [note: "Einschätzung: akzeptabel | Rot: 255 | Grün: 229 | Blau: 153"]
  GRZ [note: "Einschätzung: Grenzrisiko erreicht | Rot: 237 | Grün: 125 | Blau: 49"]
  IRZ [note: "Einschätzung: Individuelle Risikobewertung zwingend erforderlich! | Rot: 68 | Grün: 114 | Blau: 196"]
}

