  Brenner_Baujahr int [note: '§ 19_B | Baujahr des Brenners.']
  Brenner_Errichtungsdatum date [note: '§ 19_B | Errichtungs oder Einbaudatum des Brenners.']
  Brenner_Leistung_min float [note: '§ 19_B | Leistung min. des Brenners in kW.']
  Brenner_Leistung_max float [note: '§ 19_B | Leistung max. des Brenners in kW.']
  Brenner_Leistung_mess float [note: '§ 19_B | Leistung des Brenners in kW bei Messung.']
  Ueber_Durchgangshoehe bool [note: 'QS | Merkmal, ob Feuerstaette ueber Durchgangshoehe liegt.']
  Bearbeitungszyklus_KUEO _Bearbeitungszyklus [note: '§ 19_K | Zyklus nach KUEO | Siehe Kennzeichnungstabelle 4.2']
  Bearbeitungszyklus_BImSchV _Bearbeitungszyklus [note: '§ 19_K | Zyklus nach 1. BImSchV | Siehe Kennzeichnungstabelle 4.2']
  // TODO macht diese Angabe Sinn?
  // Jaehrliche_Haeufigkeit int [note: '§ 19_K | Anzahl der jaehrlichen Ueberpruefung der Feuerstaette. Abhaengig vom Bearbeitungszyklus, Bearbeitungszyklus = 1.']
  Bemerkung text [note: 'QS | Bemerkung zur Feuerstaette.']
  gueltig_von date [note: '§ 19_B | Datum, ab wann die Feuerstaette Gueltigkeit besitzt. Stichwort: Erhebung (Statistische Auswertbarkeit)']
  gueltig_bis date [note: '§ 19_B | Datum bis wann die Feuerstaette Gueltigkeit besitzt. Stichwort: Erhebung (Statistische Auswertbarkeit)']
  Warmwasser_Leistung_min float [note: 'QS | Leistung min. der Warmwasseranlage in kW.']
  Warmwasser_Leistung_max float [note: 'QS | Leistung max. der Warmwasseranlage in kW.']
  Warmwasser_Leistung_eingest float [note: 'QS | eingestellte Leistung der Warmwasseranlage in kW.']
  Zuendflamme bool [note: 'QS | Merkmal, ob die Gasfeuerstaette eine Zuendflamme hat oder nicht.']
}

Table Mess_Pruefergebnisse_Gasfeuerstaette {
  ID_Mess_Pruefergebnisse_Gasfeuerstaette int [pk, increment, unique]
  // ID_Feuerstaette int [note: 'V | Verweis auf Datenmodell Objekt Feuerstaette (ID_Feuerstaette steht stellvertretend fuer ID_Gebaeude_Gebaeudeteil +ID_Nutzungseinheit+ID_Wohnung+ID_Raum+ID_Feuerstaette). Eine Feuerstaette hat eine oder mehrere Abgaswegpruefungen und eine oder mehrere Messungen nach 1.BImSchV.']
