  Genehmigungsbeduerftig text [note: '§ 19_B | Dokumnetation, ob die Anlage möglicherweise immissionschutzrechtlich genehmigungsbedürftig ist oder nicht!']
  Baujahr int [note: '§ 19_K | Baujahr der Feuerstätte']
  Brennstoff _BrennstoffBImSchV [note: '§ 19_K | Brennstoff der Feuerstätte | Siehe Kennzeichnungstabelle 2.2.2.1']
